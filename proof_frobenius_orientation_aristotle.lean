open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

#check IsCyclotomicExtension
#check @IsPrimitiveRoot.IsCyclotomicExtension.ringOfIntegers

/-
Define zeta_int as the element zeta in the ring of integers.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

noncomputable def zeta_L : L := IsCyclotomicExtension.zeta q ℚ L

lemma zeta_L_isIntegral : IsIntegral ℤ (zeta_L q L) := by
  apply IsPrimitiveRoot.isIntegral (n := q) (K := L)
  · exact IsCyclotomicExtension.zeta_spec q ℚ L
  · exact (Fact.out : Nat.Prime q).pos

noncomputable def zeta_int : RingOfIntegers L := ⟨zeta_L q L, zeta_L_isIntegral q L⟩

/-
The ring of integers of the q-th cyclotomic field is Z[zeta].
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

theorem ringOfIntegers_eq_adjoin_zeta :
    integralClosure ℤ L = Algebra.adjoin ℤ {IsCyclotomicExtension.zeta q ℚ L} := by
      have h_int_closure : IsIntegralClosure (↥(Algebra.adjoin ℤ {IsCyclotomicExtension.zeta q ℚ L})) ℤ L := by
        have := @IsCyclotomicExtension.Rat.isIntegralClosure_adjoin_singleton_of_prime q L;
        convert this ( IsCyclotomicExtension.zeta_spec q ℚ L ) using 1
        generalize_proofs at *; (
        convert ‹IsCyclotomicExtension { q } ℚ L› using 1;
        exact Subsingleton.elim _ _);
      obtain ⟨ S, hS ⟩ := h_int_closure;
      ext x; specialize @hS x; aesop;

/-
Integral versions of Gaussian periods and their differences.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

noncomputable def gaussianPeriod_int (g : (ZMod q)ˣ) (ζ : RingOfIntegers L) (i : ℕ) : RingOfIntegers L :=
  ∑ x : H q, ζ ^ ((g ^ i * x.1 : (ZMod q)ˣ) : ZMod q).val

noncomputable def alpha_int (g : (ZMod q)ˣ) (ζ : RingOfIntegers L) : RingOfIntegers L :=
  gaussianPeriod_int q L g ζ 0 - gaussianPeriod_int q L g ζ 1

noncomputable def beta_int (g : (ZMod q)ˣ) (ζ : RingOfIntegers L) : RingOfIntegers L :=
  gaussianPeriod_int q L g ζ 1 - gaussianPeriod_int q L g ζ 2

noncomputable def gamma_int (g : (ZMod q)ˣ) (ζ : RingOfIntegers L) : RingOfIntegers L :=
  gaussianPeriod_int q L g ζ 2 - gaussianPeriod_int q L g ζ 0

/-
n is in the coset determined by coset_index.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]

lemma coset_index_spec (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq : q % 3 = 1) (n : (ZMod q)ˣ) :
    ∃ h ∈ H q, n = g ^ (coset_index q g n).val * h := by
      -- By definition of $coset_index$, there exists $k \in \{0, 1, 2\}$ such that $n = g^k \cdot h$ for some $h \in H$.
      have h_coset : ∃ k : ZMod 3, ∃ h ∈ H q, n = g ^ k.val * h := by
        -- Since $g$ is a generator of the group $(\mathbb{Z}/q\mathbb{Z})^\times$, every element $n$ can be written as $g^k$ for some integer $k$.
        obtain ⟨k, hk⟩ : ∃ k : ℕ, n = g ^ k := by
          have h_gen : ∀ n : (ZMod q)ˣ, ∃ k : ℕ, n = g ^ k := by
            intro n
            have h_order : orderOf g = q - 1 := by
              rw [ hg.eq_orderOf ]
            have h_gen : Subgroup.zpowers g = ⊤ := by
              have h_gen : Nat.card (Subgroup.zpowers g) = q - 1 := by
                rw [ Nat.card_eq_fintype_card, Fintype.card_zpowers, h_order ];
              exact Subgroup.eq_top_of_card_eq _ ( by simpa [ Nat.totient_prime Fact.out ] using h_gen );
            rw [ Subgroup.eq_top_iff' ] at h_gen;
            obtain ⟨ k, rfl ⟩ := h_gen n; use Int.toNat ( k % ( orderOf g ) ) ; simp +decide [ ← zpow_natCast, Int.toNat_of_nonneg ( Int.emod_nonneg _ <| Int.natCast_ne_zero.mpr <| ne_of_gt <| orderOf_pos g ), zpow_mod_orderOf ] ;
          exact h_gen n;
        -- Since $g$ is a generator of the group $(\mathbb{Z}/q\mathbb{Z})^\times$, we can write $k$ as $3m + r$ for some integer $m$ and $r \in \{0, 1, 2\}$.
        obtain ⟨m, r, hr⟩ : ∃ m r : ℕ, r < 3 ∧ k = 3 * m + r := by
          exact ⟨ k / 3, k % 3, Nat.mod_lt _ ( by decide ), by rw [ Nat.div_add_mod ] ⟩;
        -- Since $g^3 \in H$, we have $g^{3m} \in H$.
        have h_g3m_in_H : g ^ (3 * m) ∈ H q := by
          exact ⟨ g ^ m, by simp +decide [ pow_mul' ] ⟩;
        use r, g ^ (3 * m);
        simp_all +decide [ pow_add, pow_mul' ];
        rw [ Nat.mod_eq_of_lt hr.1, mul_comm ];
      unfold coset_index;
      rcases h_coset with ⟨ k, h, hh, rfl ⟩ ; fin_cases k <;> simp_all +decide ;
      · split_ifs <;> simp_all +decide [ mul_assoc, pow_succ, Subgroup.mul_mem_cancel_left, Subgroup.mul_mem_cancel_right ];
        simp_all +decide [ mul_assoc, mul_left_comm, val ];
      · split_ifs <;> simp_all +decide [ pow_succ, mul_assoc ];
        simp_all +decide [ val ];
        simp_all +decide [ sq, mul_assoc, Subgroup.mul_mem_cancel_left, Subgroup.mul_mem_cancel_right ]

/-
Galois action on Gaussian periods: $\sigma_n(\eta_i) = \eta_{i+k(n)}$.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

lemma sigma_gaussianPeriod (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq : q % 3 = 1) (n : (ZMod q)ˣ) (i : ℕ) :
    sigma q L n (gaussianPeriod q L g (IsCyclotomicExtension.zeta q ℚ L) i) =
    gaussianPeriod q L g (IsCyclotomicExtension.zeta q ℚ L) (i + (coset_index q g n).val) := by
      -- By `coset_index_spec`, $n = g^{k(n)} h'$ for some $h' \in H$.
      obtain ⟨h', hh'⟩ : ∃ h' ∈ H q, n = g ^ (coset_index q g n).val * h' := by
        exact?;
      -- Applying the automorphism $\sigma_n$ to the Gaussian period $\eta_i$, we get $\sigma_n(\eta_i) = \sum_{x \in H} \sigma_n(\zeta^{g^i x})$.
      have h_sigma_apply : (sigma q L n) (gaussianPeriod q L g (IsCyclotomicExtension.zeta q ℚ L) i) = ∑ x : H q, (IsCyclotomicExtension.zeta q ℚ L) ^ ((n * g ^ i * x.1 : (ZMod q)ˣ) : ZMod q).val := by
        unfold gaussianPeriod; simp +decide [ mul_assoc ] ;
        convert rfl using 2;
        rw [ sigma_zeta ];
        · rw [ ← pow_mul, ZMod.val_mul ];
          rw [ ← Nat.mod_add_div ( ( n : ZMod q ).val * ( g ^ i * ( _ : ZMod q ) ).val ) q, pow_add, pow_mul ] ; simp +decide [ IsCyclotomicExtension.zeta_pow ];
        · exact?;
      -- Since $x \mapsto h' x$ is a bijection on $H$, we can rewrite the sum as $\sum_{y \in H} \zeta^{g^{i+k(n)} y}$.
      have h_bijection : ∑ x : H q, (IsCyclotomicExtension.zeta q ℚ L) ^ ((g ^ (coset_index q g n).val * h' * g ^ i * x.1 : (ZMod q)ˣ) : ZMod q).val = ∑ y : H q, (IsCyclotomicExtension.zeta q ℚ L) ^ ((g ^ (i + (coset_index q g n).val) * y.1 : (ZMod q)ˣ) : ZMod q).val := by
        -- Since $h' \in H$, we can rewrite the sum as $\sum_{y \in H} \zeta^{g^{i+k(n)} y}$.
        have h_bijection : ∃ f : H q ≃ H q, ∀ x : H q, (g ^ (coset_index q g n).val * h' * g ^ i * x.1 : (ZMod q)ˣ) = (g ^ (i + (coset_index q g n).val) * (f x).1 : (ZMod q)ˣ) := by
          refine' ⟨ Equiv.ofBijective ( fun x => ⟨ h' * x, _ ⟩ ) ⟨ _, _ ⟩, _ ⟩;
          all_goals norm_num [ Function.Injective, Function.Surjective ];
          · exact Subgroup.mul_mem _ hh'.1 x.2;
          · intro a ha
            use h'⁻¹ * a
            simp [ha];
            exact Subgroup.mul_mem _ ( Subgroup.inv_mem _ hh'.1 ) ha;
          · simp +decide [ pow_add, mul_assoc, mul_comm, mul_left_comm ];
        obtain ⟨ f, hf ⟩ := h_bijection; rw [ ← Equiv.sum_comp f ] ; simp +decide [ hf ] ;
        conv_rhs => rw [ ← Equiv.sum_comp f ] ;
        conv_rhs => rw [ ← Equiv.sum_comp f ] ;
      convert h_bijection using 1;
      rw [ h_sigma_apply, ← hh'.2 ]

/-
The cubic character of n is the cubic character of g raised to the coset index of n.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]

lemma chi_eq_pow_coset_index (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq : q % 3 = 1) (n : (ZMod q)ˣ) :
    chi q n = (chi q g) ^ (coset_index q g n).val := by
      obtain ⟨ h, hh₁, hh₂ ⟩ := coset_index_spec q g hg hq n;
      -- Since $h$ is a cube, there exists some $x$ such that $h = x^3$. Then $h^{(q-1)/3} = (x^3)^{(q-1)/3} = x^{q-1} = 1$.
      obtain ⟨ x, hx ⟩ : ∃ x : (ZMod q)ˣ, h = x^3 := by
        rcases hh₁ with ⟨ x, _, rfl ⟩ ; exact ⟨ x, by simp +decide [ pow_succ ] ⟩ ;
      -- Substitute $h = x^3$ into the expression for $n$.
      have hn : (n : ZMod q) = (g : ZMod q) ^ (coset_index q g n).val * (x : ZMod q) ^ 3 := by
        simpa [ hx ] using congr_arg ( ( ↑ ) : ( ZMod q ) ˣ → ZMod q ) hh₂;
      unfold chi; norm_num [ hn, pow_right_comm ] ; ring;
      rw [ Nat.div_mul_cancel ( show 3 ∣ q - 1 from Nat.dvd_of_mod_eq_zero ( by omega ) ) ] ; norm_num [ ZMod.pow_card_sub_one_eq_one ] ;

/-
Galois action on alpha.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

lemma sigma_alpha_int (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq : q % 3 = 1) (n : (ZMod q)ˣ) :
    sigma_int q L n (alpha_int q L g (zeta_int q L)) =
    if coset_index q g n = 0 then alpha_int q L g (zeta_int q L)
    else if coset_index q g n = 1 then beta_int q L g (zeta_int q L)
    else gamma_int q L g (zeta_int q L) := by
      -- Apply the results from `sigma_gaussianPeriod_int` to rewrite the left-hand side of the equation.
      have h_sigma_gaussianPeriod : ∀ i : ℕ, (sigma q L n) ((gaussianPeriod q L g (IsCyclotomicExtension.zeta q ℚ L) i : L)) =
          (gaussianPeriod q L g (IsCyclotomicExtension.zeta q ℚ L) (i + (coset_index q g n).val) : L) := by
            exact?;
      have h_sigma_gaussianPeriod_int : ∀ i : ℕ, (sigma_int q L n) (gaussianPeriod_int q L g (zeta_int q L) i : (RingOfIntegers L)) =
          (gaussianPeriod_int q L g (zeta_int q L) (i + (coset_index q g n).val) : (RingOfIntegers L)) := by
            intro i
            have h_gaussianPeriod_int : (gaussianPeriod_int q L g (zeta_int q L) i : L) = (gaussianPeriod q L g (IsCyclotomicExtension.zeta q ℚ L) i : L) := by
              unfold gaussianPeriod_int gaussianPeriod; aesop;
            have h_gaussianPeriod_int' : (gaussianPeriod_int q L g (zeta_int q L) (i + (coset_index q g n).val) : L) = (gaussianPeriod q L g (IsCyclotomicExtension.zeta q ℚ L) (i + (coset_index q g n).val) : L) := by
              unfold gaussianPeriod_int gaussianPeriod; aesop;
            have h_sigma_int_gaussianPeriod_int : (sigma_int q L n) (gaussianPeriod_int q L g (zeta_int q L) i : (RingOfIntegers L)) =
                (sigma q L n) (gaussianPeriod_int q L g (zeta_int q L) i : L) := by
                  unfold sigma_int;
                  simp +decide [ RingOfIntegers.mapRingEquiv ]
            aesop;
      -- Apply the results from `h_sigma_gaussianPeriod_int` to rewrite the left-hand side of the equation.
      have h_sigma_alpha : (sigma_int q L n) (alpha_int q L g (zeta_int q L)) =
          (gaussianPeriod_int q L g (zeta_int q L) ((coset_index q g n).val)) -
          (gaussianPeriod_int q L g (zeta_int q L) (1 + (coset_index q g n).val)) := by
            unfold alpha_int; aesop;
      rcases h : coset_index q g n with ( _ | _ | _ | k ) <;> simp_all +decide [ add_comm ] ; tauto;
      · rfl;
      · simp +decide [ val ];
        simp +decide [ ZMod, Fin.ext_iff ];
        unfold gaussianPeriod_int gamma_int; simp +decide [ Finset.sum_range_succ ] ;
        unfold gaussianPeriod_int; simp +decide [ Finset.sum_range_succ ] ;
        refine' Finset.sum_bij ( fun x _ => ⟨ g ^ 3 * x, _ ⟩ ) _ _ _ _ <;> simp +decide [ pow_succ, mul_assoc ];
        · unfold H; simp +decide [ pow_succ, mul_assoc ] ;
          rcases x with ⟨ x, hx ⟩ ; rcases hx with ⟨ y, _, rfl ⟩ ; use g * y; simp +decide [ mul_assoc, pow_succ ] ;
          grind;
        · intro a ha; use a * g⁻¹ ^ 3; simp_all +decide [ pow_succ, mul_assoc ] ;
          simp_all +decide [ ← mul_assoc, H ];
          obtain ⟨ x, rfl ⟩ := ha; use x * g⁻¹; group;
          simp +decide [ mul_pow, zpow_neg, zpow_ofNat ];
      · grind

/-
n is in the coset determined by coset_index.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]

lemma coset_index_prop (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq : q % 3 = 1) (n : (ZMod q)ˣ) :
    ∃ h ∈ H q, n = g ^ (coset_index q g n).val * h := by
      exact?

/-
The cardinality of H is (q-1)/3.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]

lemma card_H (hq : q % 3 = 1) : Nat.card (H q) = (q - 1) / 3 := by
  -- Let $G = (\mathbb{Z}/q\mathbb{Z})^\times$. Since $q \equiv 1 \pmod{3}$, the group $G$ is cyclic of order $q-1$.
  set G : Type := (ZMod q)ˣ
  have hG_cyclic : IsCyclic G := by
    infer_instance
  have hG_order : Nat.card G = q - 1 := by
    norm_num [ Nat.totient_prime Fact.out ];
    rw [ ZMod.card_units ];
  -- Let $H$ be the subgroup of $G$ consisting of cubic residues. Since $G$ is cyclic of order $q-1$, $H$ has order $(q-1)/3$.
  have hH_order : Nat.card (Subgroup.zpowers (Classical.choose (IsCyclic.exists_generator (α := G)) ^ 3)) = (q - 1) / 3 := by
    rw [ Nat.card_zpowers ];
    rw [ orderOf_pow' ] <;> norm_num [ hG_order ];
    rw [ ← hG_order, orderOf_eq_card_of_forall_mem_zpowers ];
    · rw [ Nat.gcd_eq_right ( hG_order.symm ▸ Nat.dvd_of_mod_eq_zero ( by omega ) ) ];
    · exact fun x => Classical.choose_spec ( IsCyclic.exists_generator ( α := G ) ) x;
  convert hH_order using 3;
  ext; simp [H];
  constructor <;> intro h;
  · obtain ⟨ x, rfl ⟩ := h;
    obtain ⟨ k, rfl ⟩ := Classical.choose_spec ( IsCyclic.exists_generator ( α := G ) ) x; exact ⟨ k, by group ⟩ ;
  · obtain ⟨ k, rfl ⟩ := h; exact ⟨ Classical.choose ( IsCyclic.exists_generator ( α := G ) ) ^ k, by group ⟩ ;

/-
sigma_N(zeta) = zeta^N.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

lemma sigma_N_zeta (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q) :
  sigma_N q L N hNq (zeta_int q L) = (zeta_int q L) ^ N := by
    apply Subtype.ext
    generalize_proofs at *;
    convert sigma_zeta q L ( Units.mk0 ( N : ZMod q ) _ ) ( IsCyclotomicExtension.zeta q ℚ L ) _ using 1 <;> norm_num [ zeta_L ] at *;
    rw [ ← Nat.mod_add_div N q ] ; norm_num [ pow_add, pow_mul, zeta_int ] ;
    erw [ show ( ⟨ IsCyclotomicExtension.zeta q ℚ L, zeta_L_isIntegral q L ⟩ ^ q : Subtype ( fun x : L => x ∈ integralClosure ℤ L ) ) = 1 from _ ] ; simp +decide [ pow_mul' ] ; aesop;
    exact Subtype.ext ( by simp +decide [ IsCyclotomicExtension.zeta_pow ] )

/-
The Artin property: $\sigma_N(x) \equiv x^N \pmod P$.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

theorem artin_property (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (x : RingOfIntegers L) :
    Ideal.Quotient.mk P (sigma_N q L N hNq x) = (Ideal.Quotient.mk P x) ^ N := by
      -- By definition of the Artin map, we know that $\sigma_N$ acts as the Frobenius automorphism on the residue field.
      have h_artin : ∀ x : (RingOfIntegers L), Ideal.Quotient.mk P (sigma_N q L N hNq x) = Ideal.Quotient.mk P x ^ N := by
        intro x
        have h_residue : ∀ y : (RingOfIntegers L), Ideal.Quotient.mk P (sigma_N q L N hNq y) = Ideal.Quotient.mk P y ^ N := by
          intro y
          have h_residue : Ideal.Quotient.mk P (sigma_N q L N hNq y) = Ideal.Quotient.mk P y ^ N := by
            have h_zeta : Ideal.Quotient.mk P (sigma_N q L N hNq (zeta_int q L)) = Ideal.Quotient.mk P (zeta_int q L) ^ N := by
              convert congr_arg ( Ideal.Quotient.mk P ) ( sigma_N_zeta q L N hNq ) using 1
            have h_gen : ∀ y : (RingOfIntegers L), y ∈ Algebra.adjoin ℤ {zeta_int q L} → Ideal.Quotient.mk P (sigma_N q L N hNq y) = Ideal.Quotient.mk P y ^ N := by
              intro y hy
              induction' hy using Algebra.adjoin_induction with y hy ih;
              · aesop;
              · erw [ Ideal.Quotient.eq ] at * ; simp_all +decide [ Ideal.mem_span_singleton ] ;
                have h_cong : (ih : ℤ) ^ N ≡ ih [ZMOD N] := by
                  haveI := Fact.mk ( Fact.out : Nat.Prime N ) ; simp +decide [ ← ZMod.intCast_eq_intCast_iff ] ;
                obtain ⟨ k, hk ⟩ := h_cong.symm.dvd;
                convert P.mul_mem_left ( -k : RingOfIntegers L ) ( show ( N : RingOfIntegers L ) ∈ P from ?_ ) using 1 ; ring;
                · norm_cast; linarith;
                · have := ‹P.LiesOver ( span { ( N : ℤ ) } ) ›.1.symm ▸ Ideal.mem_span_singleton_self ( N : ℤ ) ; aesop;
              · have h_frobenius : ∀ (x y : (𝓞 L) ⧸ P), (x + y) ^ N = x ^ N + y ^ N := by
                  intro x y
                  have h_char : ringChar ((𝓞 L) ⧸ P) = N := by
                    have h_char : Ideal.Quotient.mk P (algebraMap ℤ (𝓞 L) N) = 0 := by
                      rw [ Ideal.Quotient.eq_zero_iff_mem ];
                      have := ‹P.LiesOver ( span { ( N : ℤ ) } ) ›.1; simp_all +decide [ Ideal.mem_span_singleton ] ;
                      replace this := SetLike.ext_iff.mp this ( N : ℤ ) ; simp_all +decide [ Ideal.mem_span_singleton ] ;
                    have h_char : ringChar ((𝓞 L) ⧸ P) ∣ N := by
                      rw [ ← CharP.cast_eq_zero_iff (𝓞 L ⧸ P) ] ; aesop;
                    rw [ Nat.dvd_prime Fact.out ] at h_char;
                    exact h_char.resolve_left ( by have := ringChar.spec ( (𝓞 L) ⧸ P ) 1; aesop )
                  haveI := Fact.mk ( show Nat.Prime N from Fact.out ) ; simp +decide [ ← h_char, add_pow_char ] ;
                  haveI := Fact.mk ( show Nat.Prime ( ringChar (𝓞 L ⧸ P) ) from h_char.symm ▸ Fact.out ) ; simp +decide [ add_pow_char ] ;
                simp_all +decide [ RingHom.map_add ];
              · simp_all +decide [ mul_pow ];
            convert h_gen y _;
            have h_gen : ∀ y : (RingOfIntegers L), y ∈ Algebra.adjoin ℤ {zeta_int q L} := by
              intro y
              have h_gen : y.val ∈ Algebra.adjoin ℤ {IsCyclotomicExtension.zeta q ℚ L} := by
                have h_gen : y.val ∈ integralClosure ℤ L := by
                  exact y.2;
                convert ringOfIntegers_eq_adjoin_zeta q L ▸ h_gen using 1
              rw [ Algebra.adjoin_singleton_eq_range_aeval ] at *;
              obtain ⟨ p, hp ⟩ := h_gen;
              use p;
              ext; simp [hp];
              convert hp using 1;
              simp +decide [ Polynomial.aeval_def, Polynomial.eval₂_eq_sum_range ];
              rfl;
            exact h_gen y
          exact h_residue
        exact h_residue x;
      exact h_artin x

/-
Checking if ringOfIntegers_eq_adjoin_zeta exists.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

#check ringOfIntegers_eq_adjoin_zeta

/-
sigma_N fixes integers.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

lemma sigma_N_int_cast (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q) (z : ℤ) :
    sigma_N q L N hNq (z : RingOfIntegers L) = z := by
      unfold sigma_N; aesop;

/-
The ring of integers of the q-th cyclotomic field is Z[zeta].
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

theorem ringOfIntegers_eq_adjoin_zeta_aux :
    integralClosure ℤ L = Algebra.adjoin ℤ {IsCyclotomicExtension.zeta q ℚ L} := by
      exact?

/-
The Artin property: $\sigma_N(x) \equiv x^N \pmod P$.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

theorem artin_property_thm (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (x : RingOfIntegers L) :
    Ideal.Quotient.mk P (sigma_N q L N hNq x) = (Ideal.Quotient.mk P x) ^ N := by
      convert ( artin_property q L N hNq P x ) using 1

/-
s2^2 = s1.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]

lemma s2_sq_eq_s1 (a : ℤ) (ha : 4 * q = a ^ 2 + 27) :
    (s2 q a) ^ 2 = s1 q a := by
      unfold s1 s2;
      by_cases h : ( 6 : ZMod q ) = 0 <;> simp_all +decide [ sq, mul_assoc ];
      field_simp [h];
      replace ha := congr_arg ( ( ↑ ) : ℤ → ZMod q ) ha ; norm_num at ha ; linear_combination' ha.symm * 1;

/-
The Dream Theorem: If c = s1, alpha^N = gamma. If c = s2, alpha^N = beta.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

theorem dream_theorem (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (a : ℤ) (ha : 4 * q = a ^ 2 + 27)
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq : q % 3 = 1)
    (h_chi_g : chi q g = s2 q a) :
    (chi q N = s1 q a → Ideal.Quotient.mk P (alpha_int q L g (zeta_int q L)) ^ N = Ideal.Quotient.mk P (gamma_int q L g (zeta_int q L))) ∧
    (chi q N = s2 q a → Ideal.Quotient.mk P (alpha_int q L g (zeta_int q L)) ^ N = Ideal.Quotient.mk P (beta_int q L g (zeta_int q L))) := by
      constructor;
      · intro hchi
        have h_k : coset_index q g (Units.mk0 (N : ZMod q) (by
        rw [ Ne.eq_def, ZMod.natCast_eq_zero_iff ] ; exact fun h => hNq <| by have := Nat.prime_dvd_prime_iff_eq ( Fact.out : Nat.Prime q ) ( Fact.out : Nat.Prime N ) ; tauto;)) = 2 := by
          all_goals generalize_proofs at *;
          have h_k : (chi q (Units.mk0 (N : ZMod q) (by
          assumption))) = (chi q g) ^ (coset_index q g (Units.mk0 (N : ZMod q) (by
          assumption))).val := by
            convert chi_eq_pow_coset_index q g hg hq ( Units.mk0 ( N : ZMod q ) ‹_› ) using 1
          generalize_proofs at *;
          have h_k : (coset_index q g (Units.mk0 (N : ZMod q) (by
          assumption))).val < 3 := by
            exact ZMod.val_lt _
          generalize_proofs at *;
          interval_cases _ : ( coset_index q g ( Units.mk0 ( N : ZMod q ) ‹_› ) ).val <;> simp_all +decide;
          · have := s2_sq_eq_s1 q a ha; simp_all +decide [ s1, s2 ] ;
            grind;
          · unfold s1 s2 at h_k;
            have h_a_zero : (a : ZMod q) = 0 := by
              by_cases h : ( 6 : ZMod q ) = 0 <;> simp_all +decide [ sub_eq_add_neg, add_assoc ];
              · rcases q with ( _ | _ | _ | _ | _ | _ | _ | q ) <;> cases h <;> trivial;
              · grind;
            replace ha := congr_arg ( ( ↑ ) : ℤ → ZMod q ) ha ; simp_all +decide;
            erw [ eq_comm, ZMod.natCast_eq_zero_iff ] at ha ; have := Nat.le_of_dvd ( by decide ) ha ; interval_cases q <;> trivial;
          · exact Fin.ext ‹_›
        generalize_proofs at *;
        have h_sigma_alpha : sigma_N q L N hNq (alpha_int q L g (zeta_int q L)) = gamma_int q L g (zeta_int q L) := by
          convert sigma_alpha_int q L g hg hq ( Units.mk0 ( N : ZMod q ) ‹_› ) using 1 ; aesop
          skip;
        rw [ ← h_sigma_alpha, ← artin_property q L N hNq ];
      · intro h;
        -- Since $k(N) = 1$, we have $\sigma_N(\alpha) = \beta$.
        have h_sigma_N_alpha : sigma_int q L (Units.mk0 (N : ZMod q) (by
        rw [ Ne.eq_def, ZMod.natCast_eq_zero_iff ] ; intro h ; have := Nat.prime_dvd_prime_iff_eq ( Fact.out : Nat.Prime q ) ( Fact.out : Nat.Prime N ) ; tauto)) (alpha_int q L g (zeta_int q L)) = beta_int q L g (zeta_int q L) := by
          all_goals generalize_proofs at *;
          have h_coset_index : (coset_index q g (Units.mk0 (N : ZMod q) (by
          assumption))).val = 1 := by
            all_goals generalize_proofs at *;
            have h_coset_index : (chi q N) = (chi q g) ^ (coset_index q g (Units.mk0 (N : ZMod q) (by
            assumption))).val := by
              convert chi_eq_pow_coset_index q g hg hq ( Units.mk0 ( N : ZMod q ) ‹_› ) using 1
            generalize_proofs at *;
            have h_order : (s2 q a) ^ 3 = 1 := by
              have h_order : (chi q g) ^ 3 = 1 := by
                have h_coset_index : (chi q g) ^ 3 = (g : ZMod q) ^ ((q - 1)) := by
                  unfold chi; ring;
                  rw [ Nat.div_mul_cancel ( show 3 ∣ q - 1 from Nat.dvd_of_mod_eq_zero ( by rw [ ← Nat.mod_add_div q 3, hq ] ; norm_num ) ) ]
                generalize_proofs at *;
                rw [ h_coset_index, ← Units.val_pow_eq_pow_val, hg.pow_eq_one ] ; norm_num
              generalize_proofs at *;
              rw [ ← h_chi_g, h_order ]
            generalize_proofs at *;
            have h_order : (coset_index q g (Units.mk0 (N : ZMod q) (by
            assumption))).val < 3 := by
              exact ZMod.val_lt _
            generalize_proofs at *;
            interval_cases _ : ( coset_index q g ( Units.mk0 ( N : ZMod q ) ‹_› ) ).val <;> simp_all +decide;
            · rw [ eq_comm ] at h ; simp_all +decide [ chi ];
              have := hg.pow_eq_one_iff_dvd; simp_all +decide [ Nat.dvd_iff_mod_eq_zero, Nat.mod_eq_of_lt ] ;
              specialize this ( ( q - 1 ) / 3 ) ; simp_all +decide [ Nat.mod_eq_of_lt ( show ( q - 1 ) / 3 < q - 1 from Nat.div_lt_self ( Nat.sub_pos_of_lt ( Nat.Prime.one_lt Fact.out ) ) ( by decide ) ) ] ;
              rcases q with ( _ | _ | _ | _ | q ) <;> simp_all +decide [ pow_succ' ];
              · exact absurd ( Fact.out ( p := Nat.Prime 1 ) ) ( by decide );
              · exact absurd ( this.mp ( by simpa [ ← Units.val_inj ] using h_chi_g ) ) ( by linarith );
            · by_cases h : s2 q a = 0 <;> simp_all +decide [ pow_succ ];
              unfold s2 at h;
              rw [ inv_eq_one_div, mul_one_div, div_eq_iff ] at h <;> norm_cast at *;
              · replace ha := congr_arg ( ( ↑ ) : ℤ → ZMod q ) ha ; simp_all +decide [ ← ZMod.intCast_eq_intCast_iff ];
                norm_num [ show ( a : ZMod q ) = 9 by linear_combination' h ] at ha;
                erw [ eq_comm, ZMod.natCast_eq_zero_iff ] at ha ; have := Nat.le_of_dvd ( by decide ) ha ; interval_cases q <;> trivial;
              · erw [ ZMod.natCast_eq_zero_iff ] ; intro H; have := Nat.le_of_dvd ( by decide ) H; interval_cases q <;> trivial;
          generalize_proofs at *;
          convert sigma_alpha_int q L g hg hq ( Units.mk0 ( N : ZMod q ) ‹_› ) using 1;
          rw [ ← ZMod.natCast_zmod_val ( coset_index q g ( Units.mk0 ( N : ZMod q ) ‹_› ) ) ] ; aesop
        generalize_proofs at *;
        rw [ ← h_sigma_N_alpha, ← artin_property_thm q L N hNq P ];
        rfl

/-
Definition of K.
-/
open Polynomial ZMod NumberField BigOperators Ideal AdjoinRoot

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (N : ℕ) [Fact (Nat.Prime N)]

abbrev K (q N : ℕ) : Type := AdjoinRoot (f q N)

/-
Definition of alpha.
-/
open Polynomial ZMod NumberField BigOperators Ideal AdjoinRoot

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (N : ℕ) [Fact (Nat.Prime N)]

noncomputable def alpha (q N : ℕ) : K q N := AdjoinRoot.root (f q N)

/-
Definition of beta.
-/
open Polynomial ZMod NumberField BigOperators Ideal AdjoinRoot

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (N : ℕ) [Fact (Nat.Prime N)]

noncomputable def beta (q N : ℕ) (a : ℤ) : K q N :=
  let α := alpha q N
  let q_K : K q N := algebraMap (ZMod N) (K q N) (q : ZMod N)
  let a_K : K q N := algebraMap (ZMod N) (K q N) (a : ZMod N)
  let two_a_inv : K q N := algebraMap (ZMod N) (K q N) (2 * (a : ZMod N))⁻¹
  two_a_inv * (6 * α^2 - (a_K + 9) * α - 4 * q_K)

/-
Definition of gamma in K as -alpha - beta.
-/
noncomputable def gamma (q N : ℕ) (a : ℤ) : K q N := - alpha q N - beta q N a

/-
The sum of alpha, beta, and gamma is zero.
-/
lemma sum_alpha_beta_gamma_zero (q : ℕ) [Fact (Nat.Prime q)]
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (g : (ZMod q)ˣ) :
    alpha_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L) = 0 := by
      unfold alpha_int beta_int gamma_int; ring;

/-
Definitions of PeriodEquation and BetaRelation. Lemma: The quotient ring O_L/P has characteristic N.
-/
def PeriodEquation (q : ℕ) [Fact (Nat.Prime q)] (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (g : (ZMod q)ˣ) : Prop :=
  (alpha_int q L g (zeta_int q L))^3 - (q : RingOfIntegers L) * (alpha_int q L g (zeta_int q L)) - (q : RingOfIntegers L) = 0

def BetaRelation (q : ℕ) [Fact (Nat.Prime q)] (a : ℤ) (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (g : (ZMod q)ˣ) : Prop :=
  2 * (a : RingOfIntegers L) * (beta_int q L g (zeta_int q L)) =
  6 * (alpha_int q L g (zeta_int q L))^2 - ((a : RingOfIntegers L) + 9) * (alpha_int q L g (zeta_int q L)) - 4 * (q : RingOfIntegers L)

lemma charP_quotient (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)] :
    CharP ((RingOfIntegers L) ⧸ P) N := by
      have h_char : (Ideal.Quotient.mk P (algebraMap ℤ (RingOfIntegers L) N)) = 0 := by
        have := ‹P.LiesOver ( span { ( N : ℤ ) } ) ›.1;
        rw [ Ideal.ext_iff ] at this;
        specialize this N; simp_all +decide [ Ideal.mem_span_singleton ] ;
        exact Ideal.Quotient.eq_zero_iff_mem.mpr this;
      constructor;
      intro x
      constructor;
      · intro hx
        have h_div : (algebraMap ℤ (𝓞 L) x) ∈ P := by
          rw [ ← Ideal.Quotient.eq_zero_iff_mem ] ; aesop;
        have h_div : (x : ℤ) ∈ Ideal.span {(N : ℤ)} := by
          have := ‹P.LiesOver ( span { ( N : ℤ ) } ) ›.1;
          exact this.symm ▸ h_div;
        exact Int.natCast_dvd_natCast.mp ( Ideal.mem_span_singleton.mp h_div );
      · rintro ⟨ k, rfl ⟩ ; simp_all +decide [ Ideal.Quotient.eq_zero_iff_mem ] ;

/-
Checking if ZMod.algebra exists.
-/
#check ZMod.algebra

/-
The image of alpha in O_L/P is a root of f(x) = x^3 - qx - q.
-/
open Polynomial ZMod

lemma alpha_bar_is_root (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g) :
    letI := charP_quotient q N hNq L P
    Polynomial.eval₂ (ZMod.castHom (dvd_refl N) ((RingOfIntegers L) ⧸ P)) (Ideal.Quotient.mk P (alpha_int q L g (zeta_int q L))) (f q N) = 0 := by
      unfold f; simp_all +decide [ Polynomial.eval₂_sub, Polynomial.eval₂_mul, Polynomial.eval₂_X, Polynomial.eval₂_C ] ;
      convert congr_arg ( Ideal.Quotient.mk P ) h_period using 1

/-
Definition of the transfer map phi from K to O_L/P.
-/
noncomputable def transfer_map (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g) :
    K q N →+* ((RingOfIntegers L) ⧸ P) :=
  letI := charP_quotient q N hNq L P
  letI : Algebra (ZMod N) ((RingOfIntegers L) ⧸ P) := ZMod.algebra _ N
  (AdjoinRoot.liftHom (f q N) (Ideal.Quotient.mk P (alpha_int q L g (zeta_int q L))) (by
    convert alpha_bar_is_root q N hNq L P g hg hq_mod h_period
  )).toRingHom

/-
The transfer map is injective because K is a field.
-/
lemma transfer_map_injective (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g)
    (h_irred : Irreducible (f q N)) :
    Function.Injective (transfer_map q N hNq L P g hg hq_mod h_period) := by
      -- Since $K$ is a field and the transfer map is a non-zero homomorphism, it must be injective.
      have h_field : IsField (AdjoinRoot (f q N)) := by
        haveI := Fact.mk h_irred; exact @Field.toIsField ( AdjoinRoot ( f q N ) ) _;
      intro x y hxy
      by_contra h_neq
      generalize_proofs at *; (
      -- Since $x \neq y$, there exists some $z \in K$ such that $z(x - y) = 1$.
      obtain ⟨z, hz⟩ : ∃ z : K q N, z * (x - y) = 1 := by
        exact h_field.mul_inv_cancel ( sub_ne_zero_of_ne h_neq ) |> Exists.imp fun z hz => by rw [ mul_comm, hz ] ;
      generalize_proofs at *; (
      apply_fun ( transfer_map q N hNq L P g hg hq_mod h_period ) at hz ; simp_all +decide [ sub_eq_iff_eq_add ] ;))

/-
The transfer map sends alpha to alpha_bar.
-/
lemma transfer_map_alpha (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g) :
    transfer_map q N hNq L P g hg hq_mod h_period (alpha q N) = Ideal.Quotient.mk P (alpha_int q L g (zeta_int q L)) := by
      simp +decide [ transfer_map, alpha ]

/-
The transfer map sends beta to beta_bar.
-/
lemma transfer_map_beta (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g)
    (a : ℤ) (ha_gcd : Int.gcd a N = 1) (hN_odd : N % 2 = 1)
    (h_beta_rel : BetaRelation q a L g) :
    transfer_map q N hNq L P g hg hq_mod h_period (beta q N a) = Ideal.Quotient.mk P (beta_int q L g (zeta_int q L)) := by
      have h_cong : transfer_map q N hNq L P g hg hq_mod h_period (2 * a * beta q N a) = 2 * a * (Ideal.Quotient.mk P) (beta_int q L g (zeta_int q L)) := by
        have h_cong : transfer_map q N hNq L P g hg hq_mod h_period (6 * alpha q N ^ 2 - (a + 9) * alpha q N - 4 * (q : K q N)) = 6 * (Ideal.Quotient.mk P) (alpha_int q L g (zeta_int q L)) ^ 2 - (a + 9) * (Ideal.Quotient.mk P) (alpha_int q L g (zeta_int q L)) - 4 * (Ideal.Quotient.mk P) (q : RingOfIntegers L) := by
          have h_cong : transfer_map q N hNq L P g hg hq_mod h_period (6 * alpha q N ^ 2 - (a + 9) * alpha q N - 4 * (q : K q N)) = 6 * (transfer_map q N hNq L P g hg hq_mod h_period (alpha q N)) ^ 2 - (a + 9) * (transfer_map q N hNq L P g hg hq_mod h_period (alpha q N)) - 4 * (transfer_map q N hNq L P g hg hq_mod h_period (q : K q N)) := by
            simp +decide [ RingHom.map_sub, RingHom.map_mul, RingHom.map_pow, RingHom.map_add, RingHom.map_one, RingHom.map_zero ];
            erw [ show ( transfer_map q N hNq L P g hg hq_mod h_period ) 6 = 6 from ?_, show ( transfer_map q N hNq L P g hg hq_mod h_period ) 9 = 9 from ?_, show ( transfer_map q N hNq L P g hg hq_mod h_period ) 4 = 4 from ?_ ];
            · erw [ map_natCast ] ; norm_num;
            · erw [ map_natCast ] ; norm_num;
            · exact map_natCast _ _;
          convert h_cong using 1;
          rw [ transfer_map_alpha ];
          simp +decide [ transfer_map ];
        have h_cong : 2 * a * (Ideal.Quotient.mk P) (beta_int q L g (zeta_int q L)) = 6 * (Ideal.Quotient.mk P) (alpha_int q L g (zeta_int q L)) ^ 2 - (a + 9) * (Ideal.Quotient.mk P) (alpha_int q L g (zeta_int q L)) - 4 * (Ideal.Quotient.mk P) (q : RingOfIntegers L) := by
          convert congr_arg ( Ideal.Quotient.mk P ) h_beta_rel using 1;
        convert ‹ ( transfer_map q N hNq L P g hg hq_mod h_period ) ( 6 * alpha q N ^ 2 - ( a + 9 ) * alpha q N - 4 * q ) = _› using 1;
        convert congr_arg _ ( show 2 * ( a : K q N ) * beta q N a = 6 * alpha q N ^ 2 - ( a + 9 ) * alpha q N - 4 * ( q : K q N ) from ?_ ) using 1;
        unfold beta;
        have h_inv : (2 * a : ZMod N) * (2 * a : ZMod N)⁻¹ = 1 := by
          rw [ ZMod.mul_inv_of_unit ];
          have h_inv : IsUnit (a : ZMod N) := by
            rw [ isUnit_iff_exists_inv ];
            have := Int.gcd_eq_gcd_ab a N;
            exact ⟨ Int.gcdA a N, by simpa [ ← ZMod.intCast_eq_intCast_iff, ha_gcd ] using congr_arg ( fun x : ℤ => x : ℤ → ZMod N ) this.symm ⟩;
          exact IsUnit.mul ( by exact isUnit_iff_ne_zero.mpr ( by erw [ Ne.eq_def, ZMod.natCast_eq_zero_iff ] ; exact Nat.not_dvd_of_pos_of_lt Nat.zero_lt_two ( lt_of_le_of_ne ( Nat.Prime.two_le Fact.out ) ( Ne.symm <| by aesop_cat ) ) ) ) h_inv;
        convert congr_arg ( fun x : ZMod N => ( algebraMap ( ZMod N ) ( K q N ) ) x * ( 6 * alpha q N ^ 2 - ( a + 9 ) * alpha q N - 4 * q ) ) h_inv using 1 ; ring;
        · norm_num [ mul_assoc, mul_comm, mul_left_comm ] ; ring;
          erw [ show ( of ( f q N ) ) 2 = 2 by rfl ] ; ring;
        · simp +decide [ Algebra.algebraMap_eq_smul_one ];
      have h_unit : IsUnit (2 * a : (RingOfIntegers L) ⧸ P) := by
        -- Since $P$ lies over $N$, the quotient ring $(RingOfIntegers L) ⧸ P$ has characteristic $N$.
        have h_char : CharP ((RingOfIntegers L) ⧸ P) N := by
          convert charP_quotient q N hNq L P;
        have h_unit : IsUnit (2 * a : ZMod N) := by
          have h_unit : IsUnit (a : ZMod N) := by
            rw [ isUnit_iff_exists_inv ];
            have := Int.gcd_eq_gcd_ab a N;
            exact ⟨ a.gcdA N, by simpa [ ← ZMod.intCast_eq_intCast_iff, ha_gcd ] using congr_arg ( fun x : ℤ => x : ℤ → ZMod N ) this.symm ⟩;
          exact IsUnit.mul ( by exact isUnit_iff_ne_zero.mpr ( by erw [ Ne.eq_def, ZMod.natCast_eq_zero_iff ] ; exact Nat.not_dvd_of_pos_of_lt ( by decide ) ( show 2 < N from lt_of_le_of_ne ( Nat.Prime.two_le Fact.out ) ( Ne.symm <| by rintro rfl; contradiction ) ) ) ) h_unit;
        convert h_unit.map ( ZMod.castHom ( dvd_refl N ) (𝓞 L ⧸ P ) ) using 1;
        erw [ map_mul, map_ofNat ];
        norm_num +zetaDelta at *;
      have h_cancel : ∀ x y : (RingOfIntegers L) ⧸ P, 2 * a * x = 2 * a * y → x = y := by
        exact fun x y hxy => h_unit.mul_left_cancel hxy;
      apply h_cancel;
      convert h_cong using 1;
      simp +decide [ transfer_map ];
      erw [ AdjoinRoot.lift_mk ] ; norm_num

/-
The transfer map sends gamma to gamma_bar.
-/
lemma transfer_map_gamma (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g)
    (a : ℤ) (ha_gcd : Int.gcd a N = 1) (hN_odd : N % 2 = 1)
    (h_beta_rel : BetaRelation q a L g) :
    transfer_map q N hNq L P g hg hq_mod h_period (gamma q N a) = Ideal.Quotient.mk P (gamma_int q L g (zeta_int q L)) := by
      unfold gamma gamma_int;
      -- Since $\sigma_N$ is a ring homomorphism, we have $\sigma_N(\alpha + \beta) = \sigma_N(\alpha) + \sigma_N(\beta)$.
      have h_hom : (transfer_map q N hNq L P g hg hq_mod h_period) (alpha q N + beta q N a) = (Ideal.Quotient.mk P) (alpha_int q L g (zeta_int q L)) + (Ideal.Quotient.mk P) (beta_int q L g (zeta_int q L)) := by
        rw [ RingHom.map_add, transfer_map_alpha, transfer_map_beta ];
        · exact ha_gcd;
        · exact hN_odd;
        · exact h_beta_rel;
      convert congr_arg Neg.neg h_hom using 1 ; ring!;
      · convert RingHom.map_neg ( transfer_map q N hNq L P g hg hq_mod h_period ) ( alpha q N + beta q N a ) using 1 ; ring!;
      · unfold alpha_int beta_int;
        erw [ Ideal.Quotient.eq ] ; ring!;
        exact P.zero_mem

/-
The Dream Theorem transfers to K via the embedding phi.
-/
lemma transfer_dream (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g)
    (a : ℤ) (ha : 4 * q = a ^ 2 + 27) (ha_gcd : Int.gcd a N = 1) (hN_odd : N % 2 = 1)
    (h_beta_rel : BetaRelation q a L g)
    (h_chi_g : chi q g = s2 q a)
    (h_irred : Irreducible (f q N)) :
    (chi q N = s1 q a → (alpha q N) ^ N = gamma q N a) ∧
    (chi q N = s2 q a → (alpha q N) ^ N = beta q N a) := by
      constructor <;> intro h;
      · have h_alpha_gamma : Ideal.Quotient.mk P (alpha_int q L g (zeta_int q L)) ^ N = Ideal.Quotient.mk P (gamma_int q L g (zeta_int q L)) := by
          apply dream_theorem q L N hNq P a ha g hg hq_mod h_chi_g |>.1 h;
        have h_alpha_gamma : transfer_map q N hNq L P g hg hq_mod h_period (alpha q N ^ N) = transfer_map q N hNq L P g hg hq_mod h_period (gamma q N a) := by
          simp_all +decide [ transfer_map_alpha, transfer_map_gamma ];
        exact ( transfer_map_injective q N hNq L P g hg hq_mod h_period h_irred ) h_alpha_gamma;
      · apply (transfer_map_injective q N hNq L P g hg hq_mod h_period h_irred).eq_iff.mp;
        have := dream_theorem q L N hNq P a ha g hg hq_mod h_chi_g;
        simp_all +decide [ transfer_map_alpha, transfer_map_beta ]

/-
The discriminant of f is -4(-q)^3 - 27(-q)^2.
-/
lemma f_discriminant (q : ℕ) (N : ℕ) :
    (f q N).disc = -4 * (-q : ZMod N)^3 - 27 * (-q : ZMod N)^2 := by
      -- The discriminant of a cubic polynomial $x^3 + ax^2 + bx + c$ is given by $-4a^3c + a^2b^2 - 4b^3 - 27c^2 + 18abc$.
      have h_discriminant_cubic : ∀ (a b c : ZMod N), (Polynomial.X^3 + Polynomial.C a * Polynomial.X^2 + Polynomial.C b * Polynomial.X + Polynomial.C c).disc = -4 * a^3 * c + a^2 * b^2 - 4 * b^3 - 27 * c^2 + 18 * a * b * c := by
        by_cases h : Nontrivial ( ZMod N ) <;> simp_all +decide [ Polynomial.natDegree_add_eq_left_of_natDegree_lt ];
        · intro a b c; exact (by
          convert Polynomial.disc_of_degree_eq_three _ using 1;
          · norm_num [ Polynomial.coeff_X, Polynomial.coeff_C ] ; ring;
          · rw [ Polynomial.degree_add_C ] <;> erw [ Polynomial.degree_add_eq_left_of_degree_lt ] <;> erw [ Polynomial.degree_add_eq_left_of_degree_lt ] <;> by_cases ha : a = 0 <;> by_cases hb : b = 0 <;> simp +decide [ ha, hb ]);
        · rcases N with ( _ | _ | N ) <;> simp_all +decide [ ZMod, Fin.ext_iff ];
          · exact False.elim <| h <| by infer_instance;
          · exact False.elim <| h <| ⟨ 0, 1, by simp +decide ⟩;
      unfold f; convert h_discriminant_cubic 0 ( -q ) ( -q ) using 1 ; norm_num; ring;
      norm_num +zetaDelta at *

/-
The discriminant of f is non-zero in ZMod N.
-/
lemma discriminant_nonzero (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (a : ℤ) (ha : 4 * q = a ^ 2 + 27) (ha_gcd : Int.gcd a N = 1) :
    (f q N).disc ≠ 0 := by
      -- By f_discriminant, we have that the discriminant is (q * a)^2.
      have h_discriminant : (f q N).disc = (q * a)^2 := by
        convert f_discriminant q N using 1 ; ring;
        norm_cast; rw [ show ( a : ℤ ) ^ 2 = 4 * q - 27 by linarith ] ; ring;
        norm_num [ pow_succ, mul_assoc ] ; ring;
      -- Since $N$ is prime and $N \neq q$, $q$ is not zero modulo $N$.
      have hq_ne_zero : (q : ZMod N) ≠ 0 := by
        rw [ Ne.eq_def, ZMod.natCast_eq_zero_iff ] ; exact fun h => hNq <| by have := Nat.prime_dvd_prime_iff_eq ( Fact.out : Nat.Prime N ) ( Fact.out : Nat.Prime q ) ; tauto;
      by_contra h_contra;
      simp_all +decide [ mul_pow ];
      rw [ ZMod.intCast_zmod_eq_zero_iff_dvd ] at h_discriminant ; exact absurd ( Int.dvd_coe_gcd h_discriminant ( dvd_refl _ ) ) ( by norm_num [ ha_gcd ] ; exact mod_cast Nat.Prime.not_dvd_one Fact.out )

/-
beta and gamma satisfy the period equation in O_L.
-/
lemma beta_gamma_roots_in_OL (q : ℕ) [Fact (Nat.Prime q)]
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g) :
    (beta_int q L g (zeta_int q L))^3 - (q : RingOfIntegers L) * (beta_int q L g (zeta_int q L)) - (q : RingOfIntegers L) = 0 ∧
    (gamma_int q L g (zeta_int q L))^3 - (q : RingOfIntegers L) * (gamma_int q L g (zeta_int q L)) - (q : RingOfIntegers L) = 0 := by
      have h_sigma_g : sigma_int q L g (alpha_int q L g (zeta_int q L)) = beta_int q L g (zeta_int q L) := by
        -- Since $g$ is a primitive root, its coset index is $1$.
        have h_coset_index_g : coset_index q g g = 1 := by
          -- Since $g$ is a primitive root, it is not in $H$, and $g * g⁻¹ = 1$ is in $H$, so the coset index is 1.
          have h_coset_index_g : g ∉ H q ∧ g * g⁻¹ ∈ H q := by
            have h_card_H : Nat.card (H q) = (q - 1) / 3 := by
              convert card_H q hq_mod using 1
              skip
            generalize_proofs at *; (
            have h_g_not_in_H : g ∉ H q := by
              intro hg_in_H
              have h_order_g : orderOf g = q - 1 := by
                rw [ hg.eq_orderOf ]
              have h_order_g_in_H : orderOf g ∣ Nat.card (H q) := by
                have h_order_g_in_H : orderOf g ∣ Nat.card (Subgroup.zpowers g) := by
                  rw [ Nat.card_zpowers ]
                generalize_proofs at *; (
                exact h_order_g_in_H.trans ( Subgroup.card_dvd_of_le ( Subgroup.zpowers_le.mpr hg_in_H ) ))
              have h_contra : q - 1 ∣ (q - 1) / 3 := by
                aesop
              have h_contra' : 3 ∣ 1 := by
                exact absurd h_contra ( Nat.not_dvd_of_pos_of_lt ( Nat.div_pos ( Nat.le_sub_one_of_lt ( by contrapose! hq_mod; interval_cases q <;> trivial ) ) zero_lt_three ) ( Nat.div_lt_self ( Nat.sub_pos_of_lt ( Nat.Prime.one_lt Fact.out ) ) ( by decide ) ) )
              exact absurd h_contra' (by norm_num)
            generalize_proofs at *; (
            exact ⟨ h_g_not_in_H, by exact ⟨ 1, by simp +decide ⟩ ⟩))
          generalize_proofs at *; (
          unfold coset_index; aesop;)
        generalize_proofs at *; (
        convert sigma_alpha_int q L g hg hq_mod g using 1 ; aesop;)
      have h_sigma_g2 : sigma_int q L (g^2) (alpha_int q L g (zeta_int q L)) = gamma_int q L g (zeta_int q L) := by
        convert sigma_alpha_int q L g hg hq_mod ( g ^ 2 ) using 1 ; simp +decide [ pow_succ, mul_assoc ] ; ring;
        have h_not_in_H : ¬(g * g ∈ H q) := by
          -- Since $g$ is a primitive root, its order is $q-1$. The order of $g^2$ is $(q-1)/\gcd(2, q-1)$.
          have h_order_g2 : orderOf (g * g) = (q - 1) / Nat.gcd 2 (q - 1) := by
            have h_order_g2 : orderOf (g ^ 2) = (q - 1) / Nat.gcd 2 (q - 1) := by
              rw [ orderOf_pow' ] <;> norm_num [ hg.eq_orderOf ];
              rw [ Nat.gcd_comm ]
            generalize_proofs at *; (
            rwa [ pow_two ] at h_order_g2)
          generalize_proofs at *; (
          -- Since $g$ is a primitive root, its order is $q-1$. The order of $g^2$ is $(q-1)/\gcd(2, q-1)$, which is greater than $(q-1)/3$.
          have h_order_g2_gt : orderOf (g * g) > (q - 1) / 3 := by
            rcases Nat.even_or_odd' q with ⟨ k, rfl | rfl ⟩ <;> simp_all +decide [ Nat.succ_eq_add_one ];
            · have := Nat.prime_mul_iff.mp ( Fact.out : Nat.Prime ( 2 * k ) ) ; aesop;
            · exact Nat.div_lt_of_lt_mul <| by linarith [ show k > 0 from Nat.pos_of_ne_zero ( by rintro rfl; contradiction ) ] ;
          generalize_proofs at *; (
          contrapose! h_order_g2_gt
          generalize_proofs at *; (
          have h_order_g2_le : orderOf (g * g) ∣ Nat.card (H q) := by
            have h_order_g2_le : ∀ x : (ZMod q)ˣ, x ∈ H q → orderOf x ∣ Nat.card (H q) := by
              intro x hx
              have h_order_x : orderOf x ∣ Nat.card (Subgroup.zpowers x) := by
                rw [ Nat.card_eq_fintype_card, Fintype.card_zpowers ]
              generalize_proofs at *; (
              exact h_order_x.trans ( Subgroup.card_dvd_of_le ( Subgroup.zpowers_le.mpr hx ) ))
            generalize_proofs at *; (
            exact h_order_g2_le _ h_order_g2_gt)
          generalize_proofs at *; (
          exact Nat.le_of_dvd ( Nat.div_pos ( Nat.le_sub_one_of_lt ( by contrapose! hq_mod; interval_cases q <;> trivial ) ) zero_lt_three ) ( h_order_g2_le.trans ( by rw [ card_H q hq_mod ] ) )))))
        generalize_proofs at *; (
        have h_not_in_gH : ¬(g * g * g⁻¹ ∈ H q) := by
          contrapose! h_not_in_H; simp_all +decide [ mul_assoc, Subgroup.mul_mem_cancel_left ] ;
        generalize_proofs at *; (
        unfold coset_index; aesop;))
      generalize_proofs at *; (
      exact ⟨ h_sigma_g.symm ▸ by simpa using congr_arg ( sigma_int q L g ) h_period, h_sigma_g2.symm ▸ by simpa using congr_arg ( sigma_int q L ( g ^ 2 ) ) h_period ⟩ ;)

/-
beta_bar and gamma_bar are roots of f in O_L/P.
-/
lemma beta_gamma_bar_are_roots (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g) :
    letI := charP_quotient q N hNq L P
    Polynomial.eval₂ (ZMod.castHom (dvd_refl N) ((RingOfIntegers L) ⧸ P)) (Ideal.Quotient.mk P (beta_int q L g (zeta_int q L))) (f q N) = 0 ∧
    Polynomial.eval₂ (ZMod.castHom (dvd_refl N) ((RingOfIntegers L) ⧸ P)) (Ideal.Quotient.mk P (gamma_int q L g (zeta_int q L))) (f q N) = 0 := by
      unfold f; simp +decide [ ← ZMod.intCast_eq_intCast_iff ] ;
      obtain ⟨hβ, hγ⟩ := beta_gamma_roots_in_OL q L g hg hq_mod h_period;
      exact ⟨ by simpa [ ← map_pow, ← map_mul, ← map_sub, ← map_add ] using congr_arg ( Ideal.Quotient.mk P ) hβ, by simpa [ ← map_pow, ← map_mul, ← map_sub, ← map_add ] using congr_arg ( Ideal.Quotient.mk P ) hγ ⟩

/-
Definitions of alpha_bar, beta_bar, gamma_bar.
-/
noncomputable def alpha_bar (q : ℕ) [Fact (Nat.Prime q)]
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L))
    (g : (ZMod q)ˣ) : (RingOfIntegers L) ⧸ P :=
  Ideal.Quotient.mk P (alpha_int q L g (zeta_int q L))

noncomputable def beta_bar (q : ℕ) [Fact (Nat.Prime q)]
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L))
    (g : (ZMod q)ˣ) : (RingOfIntegers L) ⧸ P :=
  Ideal.Quotient.mk P (beta_int q L g (zeta_int q L))

noncomputable def gamma_bar (q : ℕ) [Fact (Nat.Prime q)]
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L))
    (g : (ZMod q)ˣ) : (RingOfIntegers L) ⧸ P :=
  Ideal.Quotient.mk P (gamma_int q L g (zeta_int q L))

/-
The symmetric functions of alpha, beta, gamma match the coefficients of f.
-/
lemma symmetric_functions_in_OL (q : ℕ) [Fact (Nat.Prime q)]
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g) :
    alpha_int q L g (zeta_int q L) * beta_int q L g (zeta_int q L) +
    beta_int q L g (zeta_int q L) * gamma_int q L g (zeta_int q L) +
    gamma_int q L g (zeta_int q L) * alpha_int q L g (zeta_int q L) = -(q : RingOfIntegers L) ∧
    alpha_int q L g (zeta_int q L) * beta_int q L g (zeta_int q L) * gamma_int q L g (zeta_int q L) = (q : RingOfIntegers L) := by
      have h_sum : alpha_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L) = 0 := by
        exact?
      have h_prod : alpha_int q L g (zeta_int q L) * beta_int q L g (zeta_int q L) * gamma_int q L g (zeta_int q L) = q := by
        have := beta_gamma_roots_in_OL q L g hg hq_mod h_period; simp_all +decide [ sub_eq_iff_eq_add ] ;
        rw [ ← eq_sub_iff_add_eq' ] at h_sum; simp_all +decide [ pow_succ, mul_assoc, mul_comm, mul_left_comm ] ;
        have := h_period; simp_all +decide [ mul_assoc, pow_three, mul_add, add_mul, mul_comm, mul_left_comm ] ; ring_nf at *;
        rename_i h; have := h.symm; simp_all +decide [ pow_three, mul_assoc, mul_comm, mul_left_comm ] ; ring_nf at *;
        have h_div : (3 : RingOfIntegers L) ≠ 0 := by
          grind;
        have h_div : (3 : RingOfIntegers L) * (-(alpha_int q L g (zeta_int q L) * beta_int q L g (zeta_int q L) ^ 2) - alpha_int q L g (zeta_int q L) ^ 2 * beta_int q L g (zeta_int q L)) = (3 : RingOfIntegers L) * q := by
          grind +ring;
        exact mul_left_cancel₀ ‹_› h_div
      have h_pair_prod : alpha_int q L g (zeta_int q L) * beta_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) * gamma_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L) * alpha_int q L g (zeta_int q L) = -q := by
        have h_beta_gamma_roots : (beta_int q L g (zeta_int q L))^3 - (q : RingOfIntegers L) * (beta_int q L g (zeta_int q L)) - (q : RingOfIntegers L) = 0 := by
          exact beta_gamma_roots_in_OL q L g hg hq_mod h_period |>.1
        generalize_proofs at *; (
        refine' mul_left_cancel₀ ( show beta_int q L g ( zeta_int q L ) ≠ 0 from _ ) _;
        · rw [ eq_comm ] at h_prod ; aesop ( simp_config := { singlePass := true } ) ;
        · grind +ring)
      exact ⟨h_pair_prod, h_prod⟩;

/-
f splits into linear factors in O_L/P.
-/
lemma f_splits_in_OLP (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g) :
    letI := charP_quotient q N hNq L P
    map (ZMod.castHom (dvd_refl N) ((RingOfIntegers L) ⧸ P)) (f q N) =
    (X - C (alpha_bar q L P g)) * (X - C (beta_bar q L P g)) * (X - C (gamma_bar q L P g)) := by
      have h_symm : alpha_bar q L P g + beta_bar q L P g + gamma_bar q L P g = 0 ∧ alpha_bar q L P g * beta_bar q L P g + beta_bar q L P g * gamma_bar q L P g + gamma_bar q L P g * alpha_bar q L P g = -(q : (𝓞 L) ⧸ P) ∧ alpha_bar q L P g * beta_bar q L P g * gamma_bar q L P g = (q : (𝓞 L) ⧸ P) := by
        have h_sum : alpha_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L) = 0 := by
          exact sum_alpha_beta_gamma_zero q L g
        have h_prod_sum : alpha_int q L g (zeta_int q L) * beta_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) * gamma_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L) * alpha_int q L g (zeta_int q L) = -(q : RingOfIntegers L) := by
          have := symmetric_functions_in_OL q L g hg hq_mod h_period; aesop;
        have h_prod : alpha_int q L g (zeta_int q L) * beta_int q L g (zeta_int q L) * gamma_int q L g (zeta_int q L) = (q : RingOfIntegers L) := by
          exact symmetric_functions_in_OL q L g hg hq_mod h_period |>.2
        simp_all +decide [ ← ZMod.intCast_eq_intCast_iff ];
        convert And.intro ( congr_arg ( Ideal.Quotient.mk P ) h_sum ) ( And.intro ( congr_arg ( Ideal.Quotient.mk P ) h_prod_sum ) ( congr_arg ( Ideal.Quotient.mk P ) h_prod ) ) using 1;
      unfold f;
      simp_all +decide [ Polynomial.ext_iff ];
      intro n; ring_nf; simp +decide [ Polynomial.coeff_X, Polynomial.coeff_C, mul_assoc, sub_mul, mul_sub, h_symm ] ;
      grind +ring

/-
The discriminant of f is equal to the product of squared differences of its roots in O_L/P.
-/
lemma discriminant_eq_product_roots (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g) :
    letI := charP_quotient q N hNq L P
    letI : Algebra (ZMod N) ((RingOfIntegers L) ⧸ P) := ZMod.algebra _ N
    (algebraMap (ZMod N) ((RingOfIntegers L) ⧸ P) (f q N).disc) =
    ((alpha_bar q L P g - beta_bar q L P g) * (beta_bar q L P g - gamma_bar q L P g) * (gamma_bar q L P g - alpha_bar q L P g))^2 := by
      -- Let's simplify the expression using the fact that multiplication and addition are commutative and associative.
      set s1 := alpha_bar q L P g + beta_bar q L P g + gamma_bar q L P g
      set s2 := alpha_bar q L P g * beta_bar q L P g + beta_bar q L P g * gamma_bar q L P g + gamma_bar q L P g * alpha_bar q L P g
      set s3 := alpha_bar q L P g * beta_bar q L P g * gamma_bar q L P g;
      -- By definition of $s1$, $s2$, and $s3$, we know that $s1 = 0$, $s2 = -q$, and $s3 = q$.
      have hs1 : s1 = 0 := by
        convert congr_arg ( Ideal.Quotient.mk P ) ( sum_alpha_beta_gamma_zero q L g ) using 1
      have hs2 : s2 = -q := by
        have := symmetric_functions_in_OL q L g hg hq_mod h_period;
        convert congr_arg ( Ideal.Quotient.mk P ) this.1 using 1
      have hs3 : s3 = q := by
        convert congr_arg ( Ideal.Quotient.mk P ) ( symmetric_functions_in_OL q L g hg hq_mod h_period |>.2 ) using 1;
      -- Substitute the values of $s1$, $s2$, and $s3$ into the discriminant formula.
      have h_discriminant : ((alpha_bar q L P g - beta_bar q L P g) * (beta_bar q L P g - gamma_bar q L P g) * (gamma_bar q L P g - alpha_bar q L P g)) ^ 2 =
        s1 ^ 2 * s2 ^ 2 - 4 * s2 ^ 3 - 4 * s1 ^ 3 * s3 - 27 * s3 ^ 2 + 18 * s1 * s2 * s3 := by
          ring;
      rw [ h_discriminant, hs1, hs2, hs3 ] ; norm_num;
      erw [ f_discriminant ] ; ring;
      norm_num +zetaDelta at *;
      field_simp;
      erw [ map_mul, map_add, map_neg, map_ofNat ] ; ring;
      erw [ map_mul, map_pow ] ; ring!;
      erw [ map_natCast, map_natCast ] ; norm_num;

/-
The roots alpha_bar, beta_bar, gamma_bar are distinct in O_L/P.
-/
lemma distinct_roots_in_OLP (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (a : ℤ) (ha : 4 * q = a ^ 2 + 27) (ha_gcd : Int.gcd a N = 1)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g) :
    letI := charP_quotient q N hNq L P
    alpha_bar q L P g ≠ beta_bar q L P g ∧
    beta_bar q L P g ≠ gamma_bar q L P g ∧
    gamma_bar q L P g ≠ alpha_bar q L P g := by
      have h_discriminant : (f q N).disc ≠ 0 := by
        exact?;
      have h_distinct : ((alpha_bar q L P g - beta_bar q L P g) * (beta_bar q L P g - gamma_bar q L P g) * (gamma_bar q L P g - alpha_bar q L P g))^2 ≠ 0 := by
        rw [ ← discriminant_eq_product_roots q N hNq L P g hg hq_mod h_period ];
        convert h_discriminant using 1;
        constructor <;> intro h <;> simp_all +decide [ Polynomial.eval₂_eq_sum_range ];
      grind

/-
Checking if distinct_roots_in_OLP exists.
-/
#check distinct_roots_in_OLP

/-
sigma_g permutes alpha, beta, gamma cyclically.
-/
lemma sigma_g_cycle (q : ℕ) [Fact (Nat.Prime q)]
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1) :
    sigma_int q L g (alpha_int q L g (zeta_int q L)) = beta_int q L g (zeta_int q L) ∧
    sigma_int q L g (beta_int q L g (zeta_int q L)) = gamma_int q L g (zeta_int q L) ∧
    sigma_int q L g (gamma_int q L g (zeta_int q L)) = alpha_int q L g (zeta_int q L) := by
      have h_sigma_g_alpha : (sigma_int q L g) (alpha_int q L g (zeta_int q L)) = beta_int q L g (zeta_int q L) := by
        -- Since $g$ is a primitive root, its coset index is $1$.
        have h_coset_g : coset_index q g g = 1 := by
          unfold coset_index
          simp [hg];
          have h_not_in_H : ¬∃ h : (ZMod q)ˣ, g = h^3 := by
            rintro ⟨ h, rfl ⟩
            generalize_proofs at *; (
            have := hg.2 ( ( q - 1 ) / 3 ) ?_ <;> norm_num at *;
            · exact Nat.not_dvd_of_pos_of_lt ( Nat.div_pos ( Nat.le_sub_one_of_lt ( by contrapose! hq_mod; interval_cases q <;> trivial ) ) zero_lt_three ) ( Nat.div_lt_self ( Nat.sub_pos_of_lt ( Nat.Prime.one_lt Fact.out ) ) ( by decide ) ) this;
            · rw [ ← pow_mul, Nat.mul_div_cancel' ( show 3 ∣ q - 1 from Nat.dvd_of_mod_eq_zero ( by omega ) ) ];
              rw [ ← ZMod.card_units q, pow_card_eq_one ])
          generalize_proofs at *; (
          contrapose! h_not_in_H; unfold H at *; aesop;);
        rw [ sigma_alpha_int q L g hg hq_mod ] ; aesop;
      have h_sigma_g_beta : (sigma_int q L g) (beta_int q L g (zeta_int q L)) = gamma_int q L g (zeta_int q L) := by
        have := sigma_alpha_int q L g hg hq_mod (g^2)
        -- Since $g$ is a primitive root, we have $\coset_index(g^2) = 2$.
        have h_coset_index_g2 : coset_index q g (g^2) = 2 := by
          -- Since $g^2$ is not in $H$, we have $coset_index(g^2) = 2$.
          have h_coset_index_g2 : ¬(g^2 ∈ H q) := by
            -- Since $g$ is a primitive root, its order is $q-1$. The subgroup $H$ is generated by $g^3$, so any element in $H$ is of the form $g^{3k}$ for some integer $k$.
            have h_order_g : orderOf g = q - 1 := by
              rw [ hg.eq_orderOf ];
            -- Since $g$ is a primitive root, its order is $q-1$. The subgroup $H$ is generated by $g^3$, so any element in $H$ is of the form $g^{3k}$ for some integer $k$. Therefore, $g^2$ cannot be in $H$ because $2$ is not a multiple of $3$.
            have h_not_in_H : ¬∃ k : ℕ, g^2 = g^(3 * k) := by
              rintro ⟨ k, hk ⟩
              have h_contra : 2 ≡ 3 * k [MOD (q - 1)] := by
                rw [ ← h_order_g, pow_eq_pow_iff_modEq ] at * ; aesop
              have h_contra' : 3 ∣ 2 := by
                exact Nat.dvd_of_mod_eq_zero ( h_contra.of_dvd ( show 3 ∣ q - 1 from Nat.dvd_of_mod_eq_zero ( by omega ) ) ▸ Nat.mod_eq_zero_of_dvd ( dvd_mul_right _ _ ) )
              norm_num at h_contra';
            contrapose! h_not_in_H;
            obtain ⟨ k, hk ⟩ := h_not_in_H;
            -- Since $k$ is in the top subgroup, which is the entire group, $k$ must be some power of $g$. Let's say $k = g^m$ for some $m$.
            obtain ⟨ m, hm ⟩ : ∃ m : ℕ, k = g^m := by
              have h_k_pow : k ∈ Subgroup.zpowers g := by
                have h_k_pow : Subgroup.zpowers g = ⊤ := by
                  have h_k_pow : Nat.card (Subgroup.zpowers g) = q - 1 := by
                    rw [ Nat.card_eq_fintype_card, Fintype.card_zpowers, h_order_g ];
                  exact Subgroup.eq_top_of_card_eq _ ( by simpa [ Nat.card_eq_fintype_card ] using h_k_pow.trans ( by simp +decide [ Nat.totient_prime Fact.out ] ) );
                aesop;
              obtain ⟨ m, rfl ⟩ := h_k_pow; use Int.toNat ( m % orderOf g ) ; simp +decide [ pow_mul, pow_orderOf_eq_one ] ;
              rw [ ← zpow_mod_orderOf ];
              rw [ ← zpow_natCast, Int.toNat_of_nonneg ( Int.emod_nonneg _ ( by linarith [ Nat.sub_pos_of_lt ( Fact.out : q > 1 ) ] ) ) ];
            exact ⟨ m, by simpa [ hm, pow_mul' ] using hk.2.symm ⟩;
          unfold coset_index;
          simp_all +decide [ pow_succ, mul_assoc ];
          intro h; simp_all +decide [ H ] ;
          obtain ⟨ x, hx ⟩ := h; specialize h_coset_index_g2 ( x * x ) ; simp_all +decide [ mul_pow ] ;
        convert this using 1;
        · rw [ ← h_sigma_g_alpha ];
          simp +decide [ sq, sigma_int ];
          -- Since sigma is a group homomorphism, we have sigma(g * g) = sigma(g) * sigma(g).
          have h_sigma_mul : sigma q L (g * g) = sigma q L g * sigma q L g := by
            exact ( IsCyclotomicExtension.autEquivPow L ( Polynomial.cyclotomic.irreducible_rat ( Fact.out : Nat.Prime q ).pos ) ).symm.map_mul _ _ ▸ rfl;
          simp +decide [ h_sigma_mul, RingOfIntegers.mapRingEquiv ];
          simp +decide [ RingOfIntegers.mapRingHom ];
        · rw [ h_coset_index_g2 ] ; simp +decide;
      have h_sigma_g_gamma : (sigma_int q L g) (alpha_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L)) = alpha_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L) := by
        rw [ sum_alpha_beta_gamma_zero ] ; aesop;
      simp_all +decide [ add_assoc ];
      linear_combination' h_sigma_g_gamma

/-
The discriminant of f is non-zero in O_L/P.
-/
lemma discriminant_ne_zero_in_OLP (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (a : ℤ) (ha : 4 * q = a ^ 2 + 27) (ha_gcd : Int.gcd a N = 1)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)] :
    letI := charP_quotient q N hNq L P
    letI : Algebra (ZMod N) ((RingOfIntegers L) ⧸ P) := ZMod.algebra _ N
    (algebraMap (ZMod N) ((RingOfIntegers L) ⧸ P) (f q N).disc) ≠ 0 := by
  letI := charP_quotient q N hNq L P
  letI : Algebra (ZMod N) ((RingOfIntegers L) ⧸ P) := ZMod.algebra _ N
  have h_ne : (f q N).disc ≠ 0 := discriminant_nonzero q N hNq a ha ha_gcd
  have h_inj : Function.Injective (algebraMap (ZMod N) ((RingOfIntegers L) ⧸ P)) := by
    exact ZMod.castHom_injective ((RingOfIntegers L) ⧸ P)
  exact fun h => h_ne (h_inj (by simpa using h))

/-
Checking frobenius definition.
-/
#check frobenius

/-
Galois automorphisms commute.
-/
lemma sigma_int_commutes (q : ℕ) [Fact (Nat.Prime q)]
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (n m : (ZMod q)ˣ) :
    RingEquiv.trans (sigma_int q L n) (sigma_int q L m) = RingEquiv.trans (sigma_int q L m) (sigma_int q L n) := by
      ext x;
      have h_comm : ∀ n m : (ZMod q)ˣ, sigma q L n ∘ sigma q L m = sigma q L m ∘ sigma q L n := by
        intro n m
        have h_comm : sigma q L (n * m) = sigma q L n * sigma q L m := by
          convert ( IsCyclotomicExtension.autEquivPow L ( Polynomial.cyclotomic.irreducible_rat ( Fact.out ( p := Nat.Prime q ) |> Nat.Prime.pos ) ) ).symm.map_mul n m using 1;
        have h_comm : sigma q L (m * n) = sigma q L m * sigma q L n := by
          exact ( IsCyclotomicExtension.autEquivPow L ( Polynomial.cyclotomic.irreducible_rat ( Fact.out : q.Prime ).pos ) ).symm.map_mul m n ▸ rfl;
        simp_all +decide [ mul_comm ];
        exact funext fun x => by simpa using congr_arg ( fun f => f x ) h_comm;
      simp_all +decide [ funext_iff ];
      convert h_comm m n x using 1

lemma frobenius_action_on_roots (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g)
    (a : ℤ) (ha : 4 * q = a ^ 2 + 27)
    (h_chi_g : chi q g = s2 q a) :
    (chi q N = s2 q a →
      (alpha_bar q L P g)^N = beta_bar q L P g ∧
      (beta_bar q L P g)^N = gamma_bar q L P g ∧
      (gamma_bar q L P g)^N = alpha_bar q L P g) ∧
    (chi q N = s1 q a →
      (alpha_bar q L P g)^N = gamma_bar q L P g ∧
      (beta_bar q L P g)^N = alpha_bar q L P g ∧
      (gamma_bar q L P g)^N = beta_bar q L P g) := by
        constructor <;> intro h <;> simp_all +decide only [PeriodEquation];
        · have h_sigma_N : sigma_N q L N hNq (alpha_int q L g (zeta_int q L)) = beta_int q L g (zeta_int q L) ∧ sigma_N q L N hNq (beta_int q L g (zeta_int q L)) = gamma_int q L g (zeta_int q L) ∧ sigma_N q L N hNq (gamma_int q L g (zeta_int q L)) = alpha_int q L g (zeta_int q L) := by
            have h_sigma_N : coset_index q g (Units.mk0 (N : ZMod q) (by
            intro hN_zero
            have h_div : q ∣ N := by
              rw [ ZMod.natCast_eq_zero_iff ] at hN_zero ; exact hN_zero
            have h_eq : q = N := by
              exact ( Nat.prime_dvd_prime_iff_eq ( Fact.out : Nat.Prime q ) ( Fact.out : Nat.Prime N ) ) |>.1 h_div ▸ rfl
            exact hNq h_eq.symm
            skip)) = 1 := by
              all_goals generalize_proofs at *;
              have h_coset_index : chi q (Units.mk0 (N : ZMod q) (by
              assumption)) = (chi q g) ^ (coset_index q g (Units.mk0 (N : ZMod q) (by
              assumption))).val := by
                all_goals generalize_proofs at *;
                exact?
              generalize_proofs at *;
              have h_coset_index : (coset_index q g (Units.mk0 (N : ZMod q) (by
              assumption))).val < 3 := by
                exact ZMod.val_lt _
              generalize_proofs at *;
              interval_cases _ : ( coset_index q g ( Units.mk0 ( N : ZMod q ) ‹_› ) ).val <;> simp_all +decide only [ZMod.natCast_zmod_eq_zero_iff_dvd];
              · simp_all +decide [ chi ];
                unfold s2 at h_coset_index;
                rw [ inv_eq_one_div, mul_one_div, div_eq_iff ] at h_coset_index <;> norm_cast at * ; simp_all +decide [ sub_eq_iff_eq_add ];
                · replace ha := congr_arg ( ( ↑ ) : ℤ → ZMod q ) ha ; simp_all +decide [ ← ZMod.intCast_eq_intCast_iff ] ;
                  norm_num at ha;
                  erw [ eq_comm, ZMod.natCast_eq_zero_iff ] at ha ; have := Nat.le_of_dvd ( by decide ) ha ; interval_cases q <;> contradiction;
                · erw [ ZMod.natCast_eq_zero_iff ] ; intro H; have := Nat.le_of_dvd ( by decide ) H; interval_cases q <;> trivial;
              · exact Fin.ext ‹_›;
              · have h_s2_sq : s2 q a ^ 2 = s1 q a := by
                  convert s2_sq_eq_s1 q a ha using 1
                  skip
                generalize_proofs at *; simp_all +decide [ sq ] ;
                by_cases h : s1 q a = 0 <;> simp_all +decide [ sq ];
                · unfold chi at h_chi_g; simp_all +decide [ ZMod.natCast_eq_zero_iff ] ;
                · unfold s1 s2 at * ; simp_all +decide [ sub_eq_iff_eq_add ] ;
                  grind
            generalize_proofs at *;
            have := sigma_alpha_int q L g hg hq_mod ( Units.mk0 ( N : ZMod q ) ‹_› ) ; simp_all +decide ;
            have h_sigma_N_beta : sigma_int q L (Units.mk0 (N : ZMod q) ‹_›) (beta_int q L g (zeta_int q L)) = gamma_int q L g (zeta_int q L) := by
              have h_sigma_N_beta : sigma_int q L (Units.mk0 (N : ZMod q) ‹_›) (beta_int q L g (zeta_int q L)) = sigma_int q L (Units.mk0 (N : ZMod q) ‹_›) (sigma_int q L g (alpha_int q L g (zeta_int q L))) := by
                have := sigma_g_cycle q L g hg hq_mod; aesop;
              generalize_proofs at *;
              have h_sigma_N_beta : sigma_int q L (Units.mk0 (N : ZMod q) ‹_›) (sigma_int q L g (alpha_int q L g (zeta_int q L))) = sigma_int q L g (sigma_int q L (Units.mk0 (N : ZMod q) ‹_›) (alpha_int q L g (zeta_int q L))) := by
                exact congr_arg ( fun f => f ( alpha_int q L g ( zeta_int q L ) ) ) ( sigma_int_commutes q L ( Units.mk0 ( N : ZMod q ) ‹_› ) g ) ▸ rfl
                skip
              generalize_proofs at *; simp_all +decide ;
              have := sigma_g_cycle q L g hg hq_mod; aesop;
            generalize_proofs at *;
            have h_sigma_N_gamma : sigma_int q L (Units.mk0 (N : ZMod q) ‹_›) (alpha_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L)) = alpha_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L) := by
              have h_sigma_N_gamma : alpha_int q L g (zeta_int q L) + beta_int q L g (zeta_int q L) + gamma_int q L g (zeta_int q L) = 0 := by
                exact?
              generalize_proofs at *; aesop;
            generalize_proofs at *; (
            simp_all +decide [ sigma_N ];
            exact eq_of_sub_eq_zero ( by rw [ ← sub_eq_zero_of_eq h_sigma_N_gamma ] ; abel1 ));
          have h_sigma_N_mod : ∀ x : RingOfIntegers L, Ideal.Quotient.mk P (sigma_N q L N hNq x) = (Ideal.Quotient.mk P x) ^ N := by
            apply_rules [ artin_property ];
          exact ⟨ h_sigma_N_mod _ ▸ h_sigma_N.1 ▸ rfl, h_sigma_N_mod _ ▸ h_sigma_N.2.1 ▸ rfl, h_sigma_N_mod _ ▸ h_sigma_N.2.2 ▸ rfl ⟩;
        · have h_sigma_N_alpha : sigma_int q L (Units.mk0 (N : ZMod q) (by
          rw [ Ne.eq_def, ZMod.natCast_eq_zero_iff ] ; exact fun h => hNq <| by have := Nat.prime_dvd_prime_iff_eq ( Fact.out : Nat.Prime q ) ( Fact.out : Nat.Prime N ) ; tauto;)) (alpha_int q L g (zeta_int q L)) = gamma_int q L g (zeta_int q L) := by
            all_goals generalize_proofs at *;
            convert sigma_alpha_int q L g hg hq_mod ( Units.mk0 ( N : ZMod q ) ‹_› ) using 1;
            have h_coset_index : chi q N = (chi q g) ^ (coset_index q g (Units.mk0 (N : ZMod q) ‹_›)).val := by
              convert chi_eq_pow_coset_index q g hg hq_mod ( Units.mk0 ( N : ZMod q ) ‹_› ) using 1
              skip
            generalize_proofs at *;
            have h_coset_index_val : (coset_index q g (Units.mk0 (N : ZMod q) ‹_›)).val = 2 := by
              have h_coset_index_val : (coset_index q g (Units.mk0 (N : ZMod q) ‹_›)).val < 3 := by
                exact ZMod.val_lt _;
              interval_cases _ : ( coset_index q g ( Units.mk0 ( N : ZMod q ) ‹_› ) |> ZMod.val ) <;> simp_all +decide;
              · have h_s1_s2 : s1 q a + s2 q a = -1 := by
                  unfold s1 s2; ring;
                  rw [ inv_mul_cancel₀ ] ; norm_num;
                  erw [ ZMod.natCast_eq_zero_iff ] ; intro H; have := Nat.le_of_dvd ( by decide ) H; interval_cases q <;> trivial;
                have h_s2_sq : s2 q a ^ 2 = s1 q a := by
                  convert s2_sq_eq_s1 q a ha using 1;
                norm_num [ ← h ] at *;
                cases h_s2_sq <;> simp_all +decide;
                rw [ eq_neg_iff_add_eq_zero ] at h_s1_s2 ; norm_num at h_s1_s2;
                erw [ ZMod.natCast_eq_zero_iff ] at h_s1_s2 ; have := Nat.le_of_dvd ( by decide ) h_s1_s2 ; interval_cases q <;> trivial;
              · have h_contra : (a - 3) * (6 : ZMod q)⁻¹ = (-a - 3) * (6 : ZMod q)⁻¹ := by
                  convert h using 1;
                have h_contra : (a : ZMod q) = 0 := by
                  have h_contra : (a : ZMod q) * 2 = 0 := by
                    have h_contra : (a - 3 : ZMod q) = (-a - 3 : ZMod q) := by
                      have h_contra : (6 : ZMod q) ≠ 0 := by
                        intro h; rcases q with ( _ | _ | _ | _ | _ | _ | _ | q ) <;> cases h <;> trivial;
                      exact mul_left_cancel₀ ( inv_ne_zero h_contra ) ( by linear_combination' ‹ ( a - 3 : ZMod q ) * 6⁻¹ = ( -a - 3 : ZMod q ) * 6⁻¹ › );
                    linear_combination' h_contra;
                  haveI := Fact.mk ( Fact.out : Nat.Prime q ) ; simp_all +decide [ ← ZMod.intCast_eq_intCast_iff ] ;
                  exact h_contra.resolve_right ( by erw [ ZMod.natCast_eq_zero_iff ] ; exact Nat.not_dvd_of_pos_of_lt ( by decide ) ( by contrapose! hNq; interval_cases q <;> trivial ) );
                replace ha := congr_arg ( ( ↑ ) : ℤ → ZMod q ) ha ; simp_all +decide [ ← ZMod.intCast_eq_intCast_iff ] ;
                erw [ eq_comm, ZMod.natCast_eq_zero_iff ] at ha ; have := Nat.le_of_dvd ( by decide ) ha ; interval_cases q <;> trivial
            generalize_proofs at *;
            rw [ if_neg, if_neg ] <;> simp_all +decide [ ZMod.val_natCast ];
            · exact fun h => by rw [ h ] at h_coset_index_val; contradiction;
            · exact fun h => by simp +decide [ h ] at h_coset_index_val;
          generalize_proofs at *;
          have h_sigma_N_beta : sigma_int q L (Units.mk0 (N : ZMod q) (by
          assumption)) (beta_int q L g (zeta_int q L)) = alpha_int q L g (zeta_int q L) := by
            all_goals generalize_proofs at *;
            have h_sigma_N_beta : sigma_int q L (Units.mk0 (N : ZMod q) (by
            assumption)) (beta_int q L g (zeta_int q L)) = sigma_int q L g (sigma_int q L (Units.mk0 (N : ZMod q) (by
            assumption)) (alpha_int q L g (zeta_int q L))) := by
              all_goals generalize_proofs at *;
              have h_sigma_N_beta : sigma_int q L (Units.mk0 (N : ZMod q) (by
              assumption)) (beta_int q L g (zeta_int q L)) = sigma_int q L (Units.mk0 (N : ZMod q) (by
              assumption)) (sigma_int q L g (alpha_int q L g (zeta_int q L))) := by
                rw [ sigma_g_cycle q L g hg hq_mod |>.1 ]
              generalize_proofs at *; (
              convert h_sigma_N_beta using 1
              generalize_proofs at *; (
              exact congr_arg ( fun f => f ( alpha_int q L g ( zeta_int q L ) ) ) ( sigma_int_commutes q L g ( Units.mk0 ( N : ZMod q ) ‹_› ) ) ▸ rfl
              skip))
            generalize_proofs at *; (
            rw [ h_sigma_N_beta, h_sigma_N_alpha, sigma_g_cycle q L g hg hq_mod |>.2.2 ])
          generalize_proofs at *;
          have h_sigma_N_gamma : sigma_int q L (Units.mk0 (N : ZMod q) (by
          assumption)) (gamma_int q L g (zeta_int q L)) = beta_int q L g (zeta_int q L) := by
            all_goals generalize_proofs at *;
            have h_sigma_N_gamma : sigma_int q L (Units.mk0 (N : ZMod q) (by
            assumption)) (gamma_int q L g (zeta_int q L)) = -sigma_int q L (Units.mk0 (N : ZMod q) (by
            assumption)) (alpha_int q L g (zeta_int q L)) - sigma_int q L (Units.mk0 (N : ZMod q) (by
            assumption)) (beta_int q L g (zeta_int q L)) := by
              all_goals generalize_proofs at *;
              unfold gamma_int; simp +decide [ sub_eq_add_neg ] ;
              rw [ show alpha_int q L g ( zeta_int q L ) = gaussianPeriod_int q L g ( zeta_int q L ) 0 - gaussianPeriod_int q L g ( zeta_int q L ) 1 from rfl, show beta_int q L g ( zeta_int q L ) = gaussianPeriod_int q L g ( zeta_int q L ) 1 - gaussianPeriod_int q L g ( zeta_int q L ) 2 from rfl ] ; simp +decide [ sub_eq_add_neg, add_assoc ] ; ring;
            generalize_proofs at *;
            rw [ h_sigma_N_gamma, h_sigma_N_alpha, h_sigma_N_beta ];
            unfold gamma_int beta_int alpha_int; ring;
          generalize_proofs at *;
          have h_artin_property : ∀ x : RingOfIntegers L, Ideal.Quotient.mk P (sigma_int q L (Units.mk0 (N : ZMod q) (by
          assumption)) x) = (Ideal.Quotient.mk P x) ^ N := by
            all_goals generalize_proofs at *;
            apply_rules [ Ideal.Quotient.eq, Ideal.Quotient.eq_zero_iff_mem.mpr ];
            ext x; exact (by
            convert artin_property q L N hNq P x using 1
            skip)
          generalize_proofs at *;
          exact ⟨ by simpa [ h_sigma_N_alpha ] using Eq.symm ( h_artin_property ( alpha_int q L g ( zeta_int q L ) ) ), by simpa [ h_sigma_N_beta ] using Eq.symm ( h_artin_property ( beta_int q L g ( zeta_int q L ) ) ), by simpa [ h_sigma_N_gamma ] using Eq.symm ( h_artin_property ( gamma_int q L g ( zeta_int q L ) ) ) ⟩
          skip

/-
If c != 1, then f is irreducible over F_N.
-/
theorem irreducibility_criterion (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (a : ℤ) (ha : 4 * q = a ^ 2 + 27) (ha_gcd : Int.gcd a N = 1)
    (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]
    (P : Ideal (RingOfIntegers L)) [P.IsMaximal] [Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ)]
    (g : (ZMod q)ˣ) (hg : IsPrimitiveRoot g (q - 1)) (hq_mod : q % 3 = 1)
    (h_period : PeriodEquation q L g)
    (h_chi_g : chi q g = s2 q a) :
    chi q N ≠ 1 → Irreducible (f q N) := by
      intro h_ne_one
      by_contra h_not_irreducible
      obtain ⟨x0, hx0⟩ : ∃ x0 : ZMod N, (f q N).eval x0 = 0 := by
        have h_root : ∃ x0 : ZMod N, (f q N).eval x0 = 0 := by
          have h_deg : Polynomial.degree (f q N) = 3 := by
            erw [ Polynomial.degree_add_eq_left_of_degree_lt ] <;> erw [ Polynomial.degree_add_eq_left_of_degree_lt ] <;> norm_num [ Polynomial.degree_X_pow, Polynomial.degree_C ] ;
            · exact lt_of_le_of_lt ( add_le_add_right Polynomial.degree_C_le _ ) ( by norm_num );
            · exact lt_of_le_of_lt Polynomial.degree_C_le ( WithBot.coe_lt_coe.mpr ( by decide ) );
            · exact lt_of_le_of_lt ( add_le_add_right Polynomial.degree_C_le _ ) ( by norm_num )
          have h_not_irred : ¬ Irreducible (f q N) := h_not_irreducible
          obtain ⟨g, h, hg, hh, h_factor⟩ : ∃ g h : Polynomial (ZMod N), g.degree > 0 ∧ h.degree > 0 ∧ (f q N) = g * h := by
            rw [ irreducible_iff ] at h_not_irred
            generalize_proofs at *; (
            simp_all +decide [ Polynomial.isUnit_iff_degree_eq_zero ];
            obtain ⟨ g, h, h₁, h₂, h₃ ⟩ := h_not_irred; exact ⟨ g, lt_of_le_of_ne ( le_of_not_gt fun h => by aesop ) ( Ne.symm h₂ ), h, lt_of_le_of_ne ( le_of_not_gt fun h => by aesop ) ( Ne.symm h₃ ), h₁ ⟩ ;)
          generalize_proofs at *; (
          have h_deg_g : g.degree = 1 ∨ h.degree = 1 := by
            have h_deg_g : g.degree + h.degree = 3 := by
              rw [ ← h_deg, h_factor, Polynomial.degree_mul ]
            generalize_proofs at *; (
            rw [ Polynomial.degree_eq_natDegree ( Polynomial.ne_zero_of_degree_gt hg ), Polynomial.degree_eq_natDegree ( Polynomial.ne_zero_of_degree_gt hh ) ] at * ; norm_cast at * ; omega;)
          generalize_proofs at *; (
          rcases h_deg_g with ( h_deg_g | h_deg_g ) <;> obtain ⟨ x0, hx0 ⟩ := Polynomial.exists_root_of_degree_eq_one h_deg_g <;> use x0 <;> simp_all +decide [ Polynomial.eval_mul ] ;))
        generalize_proofs at *; (
        exact h_root)
      generalize_proofs at *; (
      -- Let $\phi$ be the ring homomorphism from $F_N$ to $O_L/P$.
      obtain ⟨ϕ, hϕ⟩ : ∃ ϕ : ZMod N →+* (RingOfIntegers L) ⧸ P, True := by
        have h_char : CharP ((RingOfIntegers L) ⧸ P) N := by
          convert charP_quotient q N hNq L P using 1
          skip
        generalize_proofs at *; (
        exact ⟨ ZMod.castHom ( dvd_refl N ) ( ( RingOfIntegers L ) ⧸ P ), trivial ⟩
        skip)
      generalize_proofs at *; (
      -- Since $\phi(x_0)$ is a root of $f_bar$ in $O_L/P$, and $\alpha_bar$, $\beta_bar$, $\gamma_bar$ are distinct roots of $f_bar$ in $O_L/P$, it must be that $\phi(x_0) = \alpha_bar$, $\beta_bar$, or $\gamma_bar$.
      have h_phi_root : ϕ x0 = alpha_bar q L P g ∨ ϕ x0 = beta_bar q L P g ∨ ϕ x0 = gamma_bar q L P g := by
        have h_phi_root : (ϕ x0 - alpha_bar q L P g) * (ϕ x0 - beta_bar q L P g) * (ϕ x0 - gamma_bar q L P g) = 0 := by
          have h_phi_root : (f q N).map ϕ = (Polynomial.X - Polynomial.C (alpha_bar q L P g)) * (Polynomial.X - Polynomial.C (beta_bar q L P g)) * (Polynomial.X - Polynomial.C (gamma_bar q L P g)) := by
            convert f_splits_in_OLP q N hNq L P g hg hq_mod h_period using 1
            generalize_proofs at *; (
            ext; simp [f])
          generalize_proofs at *; (
          replace h_phi_root := congr_arg ( Polynomial.eval ( ϕ x0 ) ) h_phi_root ; simp_all +decide [ Polynomial.eval_map ] ;)
        generalize_proofs at *; (
        simp_all +decide [ sub_eq_iff_eq_add, mul_assoc ])
      generalize_proofs at *; (
      -- Since $\phi(x_0)$ is a root of $f_bar$ in $O_L/P$, and $\alpha_bar$, $\beta_bar$, $\gamma_bar$ are distinct roots of $f_bar$ in $O_L/P$, it must be that $\phi(x_0)^N = \phi(x_0)$.
      have h_phi_root_pow : ϕ x0 ^ N = ϕ x0 := by
        rw [ ← map_pow, ZMod.pow_card ]
      generalize_proofs at *; (
      -- By `frobenius_action_on_roots`, we know that if `chi q N = s1 q a` or `chi q N = s2 q a`, then `alpha_bar^N`, `beta_bar^N`, and `gamma_bar^N` are distinct from `alpha_bar`, `beta_bar`, and `gamma_bar`.
      have h_distinct : (chi q N = s1 q a → (alpha_bar q L P g)^N ≠ alpha_bar q L P g ∧ (beta_bar q L P g)^N ≠ beta_bar q L P g ∧ (gamma_bar q L P g)^N ≠ gamma_bar q L P g) ∧
                         (chi q N = s2 q a → (alpha_bar q L P g)^N ≠ alpha_bar q L P g ∧ (beta_bar q L P g)^N ≠ beta_bar q L P g ∧ (gamma_bar q L P g)^N ≠ gamma_bar q L P g) := by
                           have := frobenius_action_on_roots q N hNq L P g hg hq_mod h_period a ha h_chi_g
                           generalize_proofs at *; (
                           have := distinct_roots_in_OLP q N hNq a ha ha_gcd L P g hg hq_mod h_period; simp_all +decide ;
                           grind)
      generalize_proofs at *; (
      -- Since `chi q N` is not equal to 1, it must be equal to `s1 q a` or `s2 q a`.
      have h_chi_cases : chi q N = s1 q a ∨ chi q N = s2 q a := by
        have h_chi_cases : ∀ n : (ZMod q)ˣ, chi q n = 1 ∨ chi q n = s1 q a ∨ chi q n = s2 q a := by
          intro n
          have h_coset : ∃ i : ℕ, i < 3 ∧ chi q n = (chi q g) ^ i := by
            have h_coset : ∃ i : ℕ, i < 3 ∧ chi q n = (chi q g) ^ i := by
              have h_coset_index : ∃ i : ℕ, i < 3 ∧ chi q n = (chi q g) ^ i := by
                have h_coset_index : chi q n = (chi q g) ^ (coset_index q g n).val := by
                  exact chi_eq_pow_coset_index q g hg hq_mod n ▸ rfl
                  skip
                exact ⟨ _, Fin.is_lt _, h_coset_index ⟩
                skip
              exact h_coset_index
            generalize_proofs at *; (
            exact h_coset)
          generalize_proofs at *; (
          rcases h_coset with ⟨ i, hi, hi' ⟩ ; interval_cases i <;> simp +decide [ * ] ;
          exact Or.inr <| Or.inl <| s2_sq_eq_s1 q a ha ▸ rfl;)
        generalize_proofs at *; (
        have h_unit : IsUnit (N : ZMod q) := by
          exact IsUnit.mk0 _ ( by rw [ Ne.eq_def, ZMod.natCast_eq_zero_iff ] ; exact fun h => hNq <| by have := Nat.prime_dvd_prime_iff_eq ( Fact.out : Nat.Prime q ) ( Fact.out : Nat.Prime N ) ; tauto )
        generalize_proofs at *; (
        obtain ⟨ n, hn ⟩ := h_unit; specialize h_chi_cases n; aesop;))
      generalize_proofs at *; (
      rcases h_phi_root with ( h | h | h ) <;> simp_all +decide [ pow_succ' ] ;))))))

/-
The Frobenius Orientation Theorem.
-/
theorem frobenius_orientation (q : ℕ) [Fact (Nat.Prime q)]
    (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q)
    (a : ℤ) (ha : 4 * q = a ^ 2 + 27) (ha_gcd : Int.gcd a N = 1) (hN_odd : N % 2 = 1)
    (h_irred : Irreducible (f q N))
    (h_valid_q : ∃ (L : Type*) (_ : Field L) (_ : Algebra ℚ L) (_ : IsCyclotomicExtension {q} ℚ L)
                   (g : (ZMod q)ˣ) (_ : IsPrimitiveRoot g (q - 1)),
                   q % 3 = 1 ∧
                   PeriodEquation q L g ∧
                   BetaRelation q a L g ∧
                   chi q g = s2 q a) :
    (chi q N = s1 q a → (alpha q N) ^ N = gamma q N a) ∧
    (chi q N = s2 q a → (alpha q N) ^ N = beta q N a) := by
      obtain ⟨ L, x, x_1, x_2, g, hg, hq_mod, h_period, h_beta_rel, h_chi_g ⟩ := h_valid_q;
      obtain ⟨P, hP_max, hP_lies⟩ : ∃ P : Ideal (RingOfIntegers L), P.IsMaximal ∧ Ideal.LiesOver P (Ideal.span {(N : ℤ)} : Ideal ℤ) := by
        obtain ⟨P, hP⟩ : ∃ P : Ideal (RingOfIntegers L), P.IsMaximal ∧ Ideal.span {(N : ℤ)} ≤ Ideal.comap (algebraMap ℤ (RingOfIntegers L)) P := by
          have h_exists_maximal : ∀ (I : Ideal ℤ), I ≠ ⊤ → ∃ P : Ideal (RingOfIntegers L), P.IsMaximal ∧ I ≤ Ideal.comap (algebraMap ℤ (RingOfIntegers L)) P := by
            intro I hI_ne_top
            obtain ⟨P, hP_max, hP_cont⟩ : ∃ P : Ideal (RingOfIntegers L), P.IsMaximal ∧ Ideal.map (algebraMap ℤ (RingOfIntegers L)) I ≤ P := by
              have h_exists_maximal : ∀ (I : Ideal (RingOfIntegers L)), I ≠ ⊤ → ∃ P : Ideal (RingOfIntegers L), P.IsMaximal ∧ I ≤ P := by
                exact fun I hI_ne_top => Ideal.exists_le_maximal I hI_ne_top;
              apply h_exists_maximal;
              rw [ Ne.eq_def, Ideal.map_eq_top_iff ] ; aesop;
              · intro x y hxy; aesop;
              · intro x; exact (by
                exact x.isIntegral);
            exact ⟨ P, hP_max, fun x hx => hP_cont <| Ideal.mem_map_of_mem _ hx ⟩;
          apply h_exists_maximal;
          rw [ Ne.eq_def, Ideal.span_singleton_eq_top ];
          rw [ isUnit_iff_dvd_one ] ; norm_cast ; exact Nat.Prime.not_dvd_one Fact.out;
        refine' ⟨ P, hP.1, _ ⟩;
        have hLiesOver : Ideal.comap (algebraMap ℤ (RingOfIntegers L)) P = Ideal.span {(N : ℤ)} := by
          have hLiesOver : Ideal.IsPrime (Ideal.comap (algebraMap ℤ (RingOfIntegers L)) P) := by
            exact hP.1.isPrime.comap _;
          have hLiesOver : Ideal.IsMaximal (Ideal.span {(N : ℤ)}) := by
            have hLiesOver : Ideal.IsMaximal (Ideal.span {(N : ℤ)}) := by
              have h_prime : Ideal.IsPrime (Ideal.span {(N : ℤ)}) := by
                rw [ Ideal.span_singleton_prime ] <;> norm_num [ Nat.Prime.ne_zero Fact.out ];
                exact Nat.prime_iff_prime_int.mp ( Fact.out : Nat.Prime N )
              convert h_prime.isMaximal;
              simp +decide [ Ideal.span_singleton_eq_bot ];
              exact Or.inl ( Nat.Prime.ne_zero Fact.out );
            exact hLiesOver;
          have := hLiesOver.1.2;
          contrapose! this;
          exact ⟨ comap ( algebraMap ℤ (𝓞 L) ) P, lt_of_le_of_ne hP.2 ( Ne.symm this ), by simpa using hP.1.ne_top ⟩;
        rw [ ← hLiesOver ];
        exact?;
      convert transfer_dream q N hNq L P g hg hq_mod h_period a ha ha_gcd hN_odd h_beta_rel h_chi_g h_irred using 1