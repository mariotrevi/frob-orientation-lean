/-
The polynomial f(x) = x^3 - qx - q over ZMod N.
-/
open Polynomial ZMod

def f (q : ℕ) (N : ℕ) : Polynomial (ZMod N) := X^3 - C (q : ZMod N) * X - C (q : ZMod N)

/-
H is the subgroup of cubic residues in (ZMod q)ˣ.
-/
open Polynomial ZMod NumberField BigOperators

variable (q : ℕ) [Fact (Nat.Prime q)]

noncomputable def H : Subgroup (ZMod q)ˣ := Subgroup.map (powMonoidHom 3) ⊤

/-
Target values s1, s2 and cubic character chi.
-/
open Polynomial ZMod NumberField BigOperators

variable (q : ℕ) [Fact (Nat.Prime q)]

noncomputable def s1 (a : ℤ) : ZMod q := (-a - 3) * (6 : ZMod q)⁻¹
noncomputable def s2 (a : ℤ) : ZMod q := (a - 3) * (6 : ZMod q)⁻¹

noncomputable def chi (n : ZMod q) : ZMod q := n ^ ((q - 1) / 3)

/-
Gaussian periods eta_i (renamed to gaussianPeriod to avoid conflict).
-/
open Polynomial ZMod NumberField BigOperators

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

noncomputable def gaussianPeriod (g : (ZMod q)ˣ) (ζ : L) (i : ℕ) : L :=
  ∑ x : H q, ζ ^ ((g ^ i * x.1 : (ZMod q)ˣ) : ZMod q).val

/-
Period differences alpha_L, beta_L, gamma_L.
-/
open Polynomial ZMod NumberField BigOperators

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

noncomputable def alpha_L (g : (ZMod q)ˣ) (ζ : L) : L := gaussianPeriod q L g ζ 0 - gaussianPeriod q L g ζ 1
noncomputable def beta_L (g : (ZMod q)ˣ) (ζ : L) : L := gaussianPeriod q L g ζ 1 - gaussianPeriod q L g ζ 2
noncomputable def gamma_L (g : (ZMod q)ˣ) (ζ : L) : L := gaussianPeriod q L g ζ 2 - gaussianPeriod q L g ζ 0

/-
Definition of the Galois automorphism sigma_n corresponding to n in (ZMod q)*.
-/
open Polynomial ZMod NumberField BigOperators

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

noncomputable def sigma (n : (ZMod q)ˣ) : L ≃ₐ[ℚ] L :=
  (IsCyclotomicExtension.autEquivPow L (Polynomial.cyclotomic.irreducible_rat (Fact.out : Nat.Prime q).pos)).symm n

/-
The Galois automorphism sigma_n maps any primitive root zeta to zeta^n.
Proof:
1. Let zeta_0 be the canonical primitive root (IsCyclotomicExtension.zeta).
2. Show sigma_n(zeta_0) = zeta_0^n using the definition of sigma and autToPow_spec.
3. Express arbitrary zeta as zeta_0^k.
4. sigma_n(zeta) = sigma_n(zeta_0^k) = (sigma_n(zeta_0))^k = (zeta_0^n)^k = zeta_0^(nk) = (zeta_0^k)^n = zeta^n.
-/
open Polynomial ZMod NumberField BigOperators

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

theorem sigma_zeta (n : (ZMod q)ˣ) (ζ : L) (hζ : IsPrimitiveRoot ζ q) :
  sigma q L n ζ = ζ ^ (n : ZMod q).val := by
    -- Let zeta_0 be the canonical primitive root (IsCyclotomicExtension.zeta).
    obtain ⟨ζ0, hζ0⟩ : ∃ ζ0 : L, IsPrimitiveRoot ζ0 q ∧ (sigma q L n) ζ0 = ζ0 ^ (n.val.val) := by
      refine' ⟨ _, IsCyclotomicExtension.zeta_spec q ℚ L, _ ⟩;
      convert IsPrimitiveRoot.autToPow_spec ℚ _ _;
      rotate_left;
      rotate_left;
      exact?;
      exact?;
      exact IsCyclotomicExtension.zeta q ℚ L;
      exact q;
      exact?;
      exact?;
      exact ⟨ Nat.Prime.ne_zero Fact.out ⟩;
      exact ( IsCyclotomicExtension.autEquivPow L ( Polynomial.cyclotomic.irreducible_rat ( Fact.out : Nat.Prime q ).pos ) ).symm n;
      · convert IsPrimitiveRoot.autToPow_spec ℚ _ _;
        rotate_left;
        rotate_left;
        exact inferInstance;
        exact inferInstance;
        exact IsCyclotomicExtension.zeta q ℚ L;
        exact q;
        exact?;
        exact?;
        exact ⟨ Nat.Prime.ne_zero Fact.out ⟩;
        exact ( IsCyclotomicExtension.autEquivPow L ( Polynomial.cyclotomic.irreducible_rat ( Fact.out : Nat.Prime q ).pos ) ).symm n;
        · exact?;
        · exact?;
      · convert IsPrimitiveRoot.autToPow_spec ℚ _ _ using 1;
        rotate_left;
        exact?;
        exact q;
        exact?;
        exact ⟨ Nat.Prime.ne_zero Fact.out ⟩;
        convert rfl;
        convert ( IsCyclotomicExtension.autEquivPow L ( Polynomial.cyclotomic.irreducible_rat ( Fact.out : Nat.Prime q ).pos ) ).apply_symm_apply n using 1;
    -- Express arbitrary zeta as zeta_0^k.
    obtain ⟨k, hk⟩ : ∃ k : ℕ, k < q ∧ ζ = ζ0 ^ k := by
      have h_basis : ∀ ζ : L, IsPrimitiveRoot ζ q → ∃ k : ℕ, k < q ∧ ζ = ζ0 ^ k := by
        intro ζ hζ
        have h_distinct : Finset.image (fun k : ℕ => ζ0 ^ k) (Finset.range q) = Multiset.toFinset (Polynomial.roots (Polynomial.X ^ q - 1 : Polynomial L)) := by
          refine' Finset.eq_of_subset_of_card_le ( _ ) _;
          · simp_all +decide [ Finset.subset_iff ];
            exact fun a ha => ⟨ ne_of_apply_ne ( Polynomial.eval 0 ) ( by simp +decide [ zero_pow ( Nat.Prime.ne_zero Fact.out ) ] ), by rw [ ← pow_mul, Nat.mul_comm, pow_mul, hζ0.1.pow_eq_one, one_pow, sub_self ] ⟩;
          · rw [ Finset.card_image_of_injOn ];
            · exact le_trans ( Multiset.toFinset_card_le _ ) ( le_trans ( Polynomial.card_roots' _ ) ( by erw [ Polynomial.natDegree_X_pow_sub_C ] ; simp +decide ) );
            · intro k hk l hl hkl; have := hζ0.1.pow_inj ( Finset.mem_range.mp hk ) ( Finset.mem_range.mp hl ) hkl; aesop;
        have h_distinct : ζ ∈ Finset.image (fun k : ℕ => ζ0 ^ k) (Finset.range q) := by
          exact h_distinct.symm ▸ Multiset.mem_toFinset.mpr ( Polynomial.mem_roots ( show ( Polynomial.X ^ q - 1 : Polynomial L ) ≠ 0 from Polynomial.X_pow_sub_C_ne_zero ( Nat.Prime.pos Fact.out ) _ ) |>.2 <| by simp +decide [ hζ.pow_eq_one ] );
        rw [ Finset.mem_image ] at h_distinct; obtain ⟨ k, hk, rfl ⟩ := h_distinct; exact ⟨ k, Finset.mem_range.mp hk, rfl ⟩ ;
      exact h_basis ζ hζ;
    simp +decide [ hk.2, hζ0.2, pow_mul ];
    ring

/-
The coset index k(n) is 0 if n is in H, 1 if n is in gH, and 2 if n is in g^2H.
-/
open Polynomial ZMod NumberField BigOperators

variable (q : ℕ) [Fact (Nat.Prime q)]

noncomputable def coset_index (g : (ZMod q)ˣ) (n : (ZMod q)ˣ) : ZMod 3 :=
  if n ∈ H q then 0
  else if n * g⁻¹ ∈ H q then 1
  else 2

/-
The Galois automorphism sigma restricted to the ring of integers.
-/
open Polynomial ZMod NumberField BigOperators

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

noncomputable def sigma_int (n : (ZMod q)ˣ) : RingOfIntegers L ≃+* RingOfIntegers L :=
  NumberField.RingOfIntegers.mapRingEquiv (sigma q L n).toRingEquiv

/-
The Galois automorphism corresponding to N mod q.
-/
open Polynomial ZMod NumberField BigOperators Ideal

variable (q : ℕ) [Fact (Nat.Prime q)]
variable (L : Type*) [Field L] [Algebra ℚ L] [IsCyclotomicExtension {q} ℚ L]

noncomputable def sigma_N (N : ℕ) [Fact (Nat.Prime N)] (hNq : N ≠ q) : RingOfIntegers L ≃+* RingOfIntegers L :=
  sigma_int q L (Units.mk0 (N : ZMod q) (by
    intro h
    have h_dvd : q ∣ N := (ZMod.natCast_zmod_eq_zero_iff_dvd N q).mp h
    have h_eq : q = N := (Nat.prime_dvd_prime_iff_eq (Fact.out : Nat.Prime q) (Fact.out : Nat.Prime N)).mp h_dvd
    exact hNq h_eq.symm
  ))

